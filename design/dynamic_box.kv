<DynamicActivity>:
	canvas.before:
		Color:
			rgba: 0.15, 0.17, 0.23, 0.5
		RoundedRectangle:
			size: self.size
			pos: self.pos

<DynamicProduct>:
	size_hint: 1, 0.2
	canvas.before:
		Color:
			rgba: 0.15, 0.17, 0.23, 0.5
		RoundedRectangle:
			size: self.size
			pos: self.pos
			radius: [20]
	BoxLayout:
		size: self.parent.size
		pos: self.parent.pos
		orientation: 'horizontal'
		spacing: dp(10)
		Label:
			size_hint_x: 0.01
		Label:
			text: f'[b]{root.initial}[/b]'
			size_hint: 0.3, 0.5
			pos_hint: {'center_x': 0.5, 'center_y': 0.5}
			color: 0.4, 0.31, 0.85, 1
			font_size: dp(20)
			markup: True
			canvas.before:
				Color:
					rgba: 0.20, 0.11, 0.44, 0.3
				RoundedRectangle:
					size: self.size
					pos: self.pos
					radius: [20]
		BoxLayout:
			orientation: 'vertical'
			Label:
			Label:
				text: f'[b]{root.title}[/b]'
				markup: True
				font_size: dp(13)
				text_size: self.size
				halign: 'left'
			Label:
				text: f'{root.fullname} • {root.subject}'
				text_size: self.size
				font_size: dp(13)
				color: 1,1,1,0.5
				halign: 'left'
			BoxLayout:
				orientation: 'horizontal'
				BoxLayout:
					size_hint_x: 0.7
					orientation: 'horizontal'
					Image:
						source: 'assets/star.png'
						size_hint_x: 0.5
					Label:
						text: f'[b]{root.rating}[/b]'
						markup: True
						font_size: dp(13)
						text_size: self.size
						halign: 'left'
						valign: 'center'
				Label:
					text: f"-{root.review} reviews-"
					color: 1,1,1,0.5
					font_size: dp(10)
					text_size: self.size
					halign: 'left'
					valign: 'center'
				Label:
					text: root.condition
					font_size: dp(13)
					canvas.before:
						Color:
							rgba: (1,1,1,0.1)  
						RoundedRectangle:
							size: self.size[0] + dp(2), self.size[1] + dp(2)
							pos: self.pos[0] - dp(1), self.pos[1] - dp(1)
							radius: [20]
						Color:
							rgba: (0.11, 0.12, 0.18, 1) 
						RoundedRectangle:
							size: self.size
							pos: self.pos
							radius: [20]
			Label:
				text: f'[b]₱{root.price}[/b]'
				markup: True
				font_size: dp(15)
				text_size: self.size
				color: 0.4, 0.31, 0.85, 1
				halign: 'left'
			Label:
		BoxLayout:
			size_hint_x: 0.2
			orientation: 'vertical'
			Label:
				size_hint_y: 0.3
			Image:
				size_hint: 0.7, 0.7
				source: 'assets/heart_normal.png'
			Label:
			Image:
				size_hint: 0.7, 0.7
				source: 'assets/green_shield.png'
			Label:
				size_hint_y: 0.3
		Label:
			size_hint_x: 0.01
			
			

<DynamicService>:
	size_hint: 1, 0.2
	canvas.before:
		Color:
			rgba: 0.15, 0.17, 0.23, 0.5
		RoundedRectangle:
			size: self.size
			pos: self.pos					