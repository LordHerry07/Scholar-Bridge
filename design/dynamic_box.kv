# -----------------------------------------------------------
# Polished Listing Card (Used for both Product and Service)
# -----------------------------------------------------------
<DynamicProduct>:
    size_hint_y: None
    height: dp(110)
    padding: dp(15)
    spacing: dp(15)
    # Background click animation
    canvas.before:
        Color:
            rgba: (0.15, 0.16, 0.22, 1) if self.state == 'normal' else (0.20, 0.21, 0.28, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(15)]
            
    # Avatar Box
    FloatLayout:
        size_hint_x: None
        width: dp(50)
        canvas.before:
            Color:
                rgba: 0.43, 0.33, 0.85, 1
            Ellipse:
                pos: [self.center_x - dp(25), self.center_y - dp(25)]
                size: dp(50), dp(50)
        Label:
			pos_hint: {'center_x': 0.5, 'center_y': 0.5}
            text: f'[b]{root.initial}[/b]'
            markup: True
            font_size: sp(16)
            
    # Details Box
    BoxLayout:
        orientation: 'vertical'
        spacing: dp(2)
        Label:
            text: f'[b]{root.title}[/b]'
            markup: True
            font_size: sp(15)
            text_size: self.size
            halign: 'left'
            valign: 'bottom'
            color: 1, 1, 1, 1
        Label:
            text: f'{root.product_type} • {root.condition}'
            font_size: sp(12)
            color: 0.6, 0.6, 0.6, 1
            text_size: self.size
            halign: 'left'
            valign: 'middle'
        Label:
            text: f'By {root.fullname}'
            font_size: sp(11)
            color: 0.4, 0.4, 0.4, 1
            text_size: self.size
            halign: 'left'
            valign: 'top'
            
    # Price Box
    BoxLayout:
        size_hint_x: None
        width: dp(70)
        orientation: 'vertical'
        Label:
            text: f'[b]₱{root.price:,.2f}[/b]'
            markup: True
            font_size: sp(14)
            color: 0.43, 0.33, 0.85, 1
            text_size: self.size
            halign: 'right'
            valign: 'middle'
<DynamicActivity>:
	canvas.before:
		Color:
			rgba: 0.15, 0.17, 0.23, 0.5
		RoundedRectangle:
			size: self.size
			pos: self.pos

<DynamicService>:
	size_hint: 1, 0.2
	canvas.before:
		Color:
			rgba: 0.15, 0.17, 0.23, 0.5
		RoundedRectangle:
			size: self.size
			pos: self.pos					

<TransactionTile>:
    size_hint_y: None
    height: dp(65)
    padding: dp(15)
    spacing: dp(10)
    canvas.before:
        Color:
            rgba: 1, 1, 1, 0.05
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(12)]
    BoxLayout:
        orientation: 'vertical'
        Label:
            id: desc_label       # Using ID instead of root.property
            text: ''
            markup: True
            font_size: sp(14)
            text_size: self.size
            halign: 'left'
            valign: 'bottom'
        Label:
            id: date_label       # Using ID instead of root.property
            text: ''
            color: 0.6, 0.6, 0.6, 1
            font_size: sp(11)
            text_size: self.size
            halign: 'left'
            valign: 'top'
    Label:
        id: amount_label         # Using ID instead of root.property
        text: ''
        markup: True
        font_size: sp(15)
        bold: True
        size_hint_x: None
        width: dp(90)
        text_size: self.size
        halign: 'right'
        valign: 'middle'
