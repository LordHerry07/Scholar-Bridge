# ==========================================
# DOMAIN: MARKETPLACE CARDS
# ==========================================

# -------------------------------
# COMPONENT: Product Listing
# -------------------------------
<DynamicProduct>:
    size_hint_y: None
    height: dp(120)
    padding: dp(15)
    spacing: dp(15)
    canvas.before:
        Color:
            rgba: 0.11, 0.12, 0.16, 1 
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(12)]
    FloatLayout:
        size_hint: None, None
        size: dp(85), dp(85)
        pos_hint: {'center_y': 0.5}
        canvas.before:
            Color:
                rgba: 0.15, 0.13, 0.22, 1 
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(12)]
        Label:
            text: root.initial
            font_size: sp(22)
            bold: True
            color: 0.6, 0.25, 0.95, 1
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
    BoxLayout:
        orientation: 'vertical'
        spacing: dp(4)
        BoxLayout:
            size_hint_y: None
            height: dp(22)
            Label:
                text: f'[b]{root.title}[/b]'
                markup: True
                font_size: sp(16)
                color: 1, 1, 1, 1
                text_size: self.size
                halign: 'left'
                valign: 'middle'
                shorten: True
                shorten_from: 'right'
            Image:
                source: 'assets/heart_outline.png' 
                size_hint_x: None
                width: dp(20)
                color: 0.5, 0.5, 0.5, 1
        Label:
            text: f'{root.fullname}   {root.subject}'
            font_size: sp(12)
            color: 0.6, 0.6, 0.6, 1
            size_hint_y: None
            height: dp(16)
            text_size: self.size
            halign: 'left'
            valign: 'middle'
            shorten: True
        BoxLayout:
            size_hint_y: None
            height: dp(20)
            spacing: dp(6)
            orientation: 'horizontal'
            Image:
                source: 'assets/star.png'
                size_hint: None, None
                size: dp(12), dp(12)
                pos_hint: {'center_y': 0.5}
                color: 0.6, 0.25, 0.95, 1 
            Label:
                text: f'[b]{root.rating}[/b]'
                markup: True
                font_size: sp(12)
                color: 1, 1, 1, 1
                size_hint_x: None
                width: self.texture_size[0]
            Label:
                text: f'({root.review} reviews)'
                font_size: sp(12)
                color: 0.5, 0.5, 0.5, 1
                size_hint_x: None
                width: self.texture_size[0]
            BoxLayout:
                size_hint: None, None
                size: self.minimum_width, dp(18)
                pos_hint: {'center_y': 0.5}
                padding: [dp(8), 0]
                canvas.before:
                    Color:
                        rgba: 0.5, 0.5, 0.5, 0.4 
                    Line:
                        rounded_rectangle: [self.x, self.y, self.width, self.height, dp(9)]
                        width: dp(1)
                Label:
                    text: root.condition
                    font_size: sp(10)
                    color: 1, 1, 1, 1
                    bold: True
                    size_hint_x: None
                    width: self.texture_size[0]
            Widget:
        BoxLayout:
            size_hint_y: None
            height: dp(24)
            Label:
                text: f'[b]₱{root.price:,.0f}[/b]' 
                markup: True
                font_size: sp(18)
                color: 0.6, 0.25, 0.95, 1 
                text_size: self.size
                halign: 'left'
                valign: 'bottom'
            BoxLayout:
                size_hint_x: None
                width: self.minimum_width
                spacing: dp(4)
                Image:
                    source: 'assets/green_shield.png' 
                    size_hint: None, None
                    size: dp(14), dp(14)
                    pos_hint: {'center_y': 0.4}
                Label:
                    text: 'Escrow'
                    font_size: sp(12)
                    color: 0.15, 0.76, 0.51, 1 
                    size_hint_x: None
                    width: self.texture_size[0]
                    pos_hint: {'center_y': 0.4}

# -------------------------------
# COMPONENT: Service Listing
# -------------------------------
<DynamicService>:
    size_hint_y: None
    height: dp(130)
    padding: dp(15)
    spacing: dp(15)
    canvas.before:
        Color:
            rgba: 0.11, 0.12, 0.16, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(12)]
    FloatLayout:
        size_hint: None, None
        size: dp(65), dp(65)
        pos_hint: {'center_y': 0.6}
        canvas.before:
            Color:
                rgba: 0.18, 0.17, 0.25, 1
            Ellipse:
                pos: self.pos
                size: self.size
        Label:
            text: root.initial
            font_size: sp(18)
            bold: True
            color: 1, 1, 1, 1
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
        Image:
            source: 'assets/green_shield.png'
            size_hint: None, None
            size: dp(16), dp(16)
            pos_hint: {'right': 1.0, 'y': 0}
    BoxLayout:
        orientation: 'vertical'
        spacing: dp(4)
        Label:
            text: f'[b]{root.title}[/b]'
            markup: True
            font_size: sp(16)
            color: 1, 1, 1, 1
            size_hint_y: None
            height: dp(20)
            text_size: self.size
            halign: 'left'
            valign: 'middle'
            shorten: True
        Label:
            text: f'{root.fullname}   {root.subject}'
            font_size: sp(12)
            color: 0.6, 0.6, 0.6, 1
            size_hint_y: None
            height: dp(16)
            text_size: self.size
            halign: 'left'
            valign: 'middle'
            shorten: True
        BoxLayout:
            size_hint_y: None
            height: dp(20)
            spacing: dp(6)
            Image:
                source: 'assets/star.png'
                size_hint: None, None
                size: dp(12), dp(12)
                pos_hint: {'center_y': 0.5}
                color: 0.6, 0.25, 0.95, 1 
            Label:
                text: f'[b]{root.rating}[/b]'
                markup: True
                font_size: sp(12)
                color: 1, 1, 1, 1
                size_hint_x: None
                width: self.texture_size[0]
            Label:
                text: f'({root.review_count})'
                font_size: sp(12)
                color: 0.5, 0.5, 0.5, 1
                size_hint_x: None
                width: self.texture_size[0]
            Label:
                text: '|'
                font_size: sp(12)
                color: 0.3, 0.3, 0.3, 1
                size_hint_x: None
                width: dp(10)
            Image:
                source: 'assets/clock.png' 
                size_hint: None, None
                size: dp(12), dp(12)
                pos_hint: {'center_y': 0.5}
                color: 0.5, 0.5, 0.5, 1
            Label:
                text: root.schedule
                font_size: sp(12)
                color: 0.5, 0.5, 0.5, 1
                size_hint_x: None
                width: self.texture_size[0]
            Widget:
        FloatLayout:
            size_hint_y: None
            height: dp(35)
            Label:
                text: f'[b]₱{root.price:,.0f}[/b][size=12sp]/{root.rate_type}[/size]' 
                markup: True
                font_size: sp(18)
                color: 0.6, 0.25, 0.95, 1
                pos_hint: {'x': 0, 'center_y': 0.3}
                size_hint: None, None
                size: self.texture_size
            Button:
                text: '[b]Book[/b]'
                markup: True
                font_size: sp(13)
                size_hint: None, None
                size: dp(70), dp(30)
                pos_hint: {'right': 1, 'center_y': 0.3}
                background_color: 0,0,0,0
                on_release: root.open_booking()
                canvas.before:
                    Color:
                        rgba: 0.5, 0.1, 0.9, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(8)]


# ==========================================
# DOMAIN: DASHBOARD & ACTIVITY
# ==========================================

# -------------------------------
# COMPONENT: Activity Overview Row
# -------------------------------
<DynamicActivity>:
    canvas.before:
        Color:
            rgba: 0.15, 0.17, 0.23, 0.5
        RoundedRectangle:
            size: self.size
            pos: self.pos

<ActivityTile>:
    size_hint_y: None
    height: dp(70)
    padding: dp(12)
    spacing: dp(15)
    canvas.before:
        Color:
            rgba: 0.11, 0.12, 0.16, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(12)]
    AnchorLayout:
        size_hint_x: None
        width: dp(45)
        canvas.before:
            Color:
                rgba: root.icon_bg_color
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(10)]
        Image:
            source: root.icon_source
            size_hint: 0.5, 0.5 
            allow_stretch: True
            keep_ratio: True
    BoxLayout:
        orientation: 'vertical'
        spacing: dp(2)
        Label:
            text: f"[b]{root.activity_type}[/b]"
            markup: True
            font_size: sp(15)
            color: 1, 1, 1, 1
            text_size: self.size
            halign: 'left'
            valign: 'bottom'
        Label:
            text: root.item_title
            font_size: sp(13)
            color: 0.5, 0.5, 0.5, 1
            text_size: self.size
            halign: 'left'
            valign: 'top'
            shorten: True
            shorten_from: 'right'
    BoxLayout:
        orientation: 'vertical'
        size_hint_x: None
        width: dp(80)
        spacing: dp(2)
        Label:
            text: f"[b]{root.amount}[/b]"
            markup: True
            font_size: sp(15)
            color: root.text_color
            text_size: self.size
            halign: 'right'
            valign: 'bottom'
        Label:
            text: root.time_ago
            font_size: sp(12)
            color: 0.5, 0.5, 0.5, 1
            text_size: self.size
            halign: 'right'
            valign: 'top'

# -------------------------------
# COMPONENT: Wallet Transaction
# -------------------------------
<TransactionTile>:
    size_hint_y: None
    height: dp(65)
    padding: dp(15)
    spacing: dp(10)
    canvas.before:
        Color:
            rgba: 1, 1, 1, 0.05
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(12)]
    BoxLayout:
        orientation: 'vertical'
        Label:
            id: desc_label
            text: ''
            markup: True
            font_size: sp(14)
            text_size: self.size
            halign: 'left'
            valign: 'bottom'
        Label:
            id: date_label
            text: ''
            color: 0.6, 0.6, 0.6, 1
            font_size: sp(11)
            text_size: self.size
            halign: 'left'
            valign: 'top'
    Label:
        id: amount_label
        text: ''
        markup: True
        font_size: sp(15)
        bold: True
        size_hint_x: None
        width: dp(90)
        text_size: self.size
        halign: 'right'
        valign: 'middle'


# ==========================================
# DOMAIN: PROFILE & SETTINGS
# ==========================================

# -------------------------------
# COMPONENT: Profile Listing Cards
# -------------------------------
<ProfileItemCard@BoxLayout>:
    title: 'Item Name'
    price: '$0.00'
    icon_color: 0.40, 0.31, 0.85, 1 
    size_hint_y: None
    height: dp(60)
    padding: dp(10)
    spacing: dp(15)
    canvas.before:
        Color:
            rgba: 0.11, 0.12, 0.18, 1 
        RoundedRectangle:
            size: self.size
            pos: self.pos
            radius: [dp(10)]
    Widget:
        size_hint_x: None
        width: dp(40)
        canvas.before:
            Color:
                rgba: root.icon_color
            RoundedRectangle:
                size: self.size
                pos: self.pos
                radius: [dp(8)]
    Label:
        text: root.title
        font_size: sp(14)
        text_size: self.size
        halign: 'left'
        valign: 'center'
        color: 1, 1, 1, 1
    Label:
        text: '[b]' + root.price + '[/b]'
        markup: True
        font_size: sp(14)
        size_hint_x: None
        width: dp(60)
        text_size: self.size
        halign: 'right'
        valign: 'center'
        color: 0.65, 0.50, 1.0, 1

# -------------------------------
# COMPONENT: Settings Rows
# -------------------------------
<SettingsToggleRow@BoxLayout>:
    title: 'Setting Name'
    active_state: False
    size_hint_y: None
    height: dp(60)
    padding: [dp(20), dp(10)]
    spacing: dp(15)
    canvas.before:
        Color:
            rgba: 0.11, 0.12, 0.18, 1 
        RoundedRectangle:
            size: self.size
            pos: self.pos
            radius: [dp(10)]
    Label:
        text: root.title
        font_size: sp(14)
        color: 1, 1, 1, 1
        text_size: self.size
        halign: 'left'
        valign: 'center'
    Switch:
        active: root.active_state
        size_hint_x: None
        width: dp(50)

<SettingsButtonRow@ButtonBehavior+BoxLayout>:
    title: 'Action Name'
    title_color: 1, 1, 1, 1
    size_hint_y: None
    height: dp(60)
    padding: [dp(20), dp(10)]
    canvas.before:
        Color:
            rgba: 0.11, 0.12, 0.18, 1
        RoundedRectangle:
            size: self.size
            pos: self.pos
            radius: [dp(10)]
    Label:
        text: root.title
        font_size: sp(14)
        color: root.title_color
        text_size: self.size
        halign: 'left'
        valign: 'center'
    Label:
        text: '>'
        font_size: sp(18)
        color: 0.5, 0.5, 0.5, 1
        size_hint_x: None
        width: dp(20)
        text_size: self.size
        halign: 'right'
        valign: 'center'
