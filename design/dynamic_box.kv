# -----------------------------------------------------
# REUSABLE COMPONENT: ITEM / SERVICE CARD
# -----------------------------------------------------
<ProfileItemCard@BoxLayout>:
    title: 'Item Name'
    price: '$0.00'
    icon_color: 0.40, 0.31, 0.85, 1  # Default to purple
    
    size_hint_y: None
    height: dp(60)
    padding: dp(10)
    spacing: dp(15)
    canvas.before:
        Color:
            rgba: 0.11, 0.12, 0.18, 1  # Card Background
        RoundedRectangle:
            size: self.size
            pos: self.pos
            radius: [dp(10)]
            
    # Tiny Icon Box
    Widget:
        size_hint_x: None
        width: dp(40)
        canvas.before:
            Color:
                rgba: root.icon_color
            RoundedRectangle:
                size: self.size
                pos: self.pos
                radius: [dp(8)]
                
    # Item Title
    Label:
        text: root.title
        font_size: sp(14)
        text_size: self.size
        halign: 'left'
        valign: 'center'
        color: 1, 1, 1, 1
        
    # Price Tag
    Label:
        text: '[b]' + root.price + '[/b]'
        markup: True
        font_size: sp(14)
        size_hint_x: None
        width: dp(60)
        text_size: self.size
        halign: 'right'
        valign: 'center'
        color: 0.65, 0.50, 1.0, 1  # Neon purple text

# -----------------------------------------------------
# MAIN PROFILE SCREEN
# -----------------------------------------------------
<ProfileInterface>:
    canvas.before:
        Color:
            rgba: 0.08, 0.09, 0.14, 1  # App Background
        Rectangle:
            size: self.size
            pos: self.pos

    ScrollView:
        do_scroll_x: False
        do_scroll_y: True
        
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height
            padding: dp(20)
            spacing: dp(25)
            
            # --- 1. THE PROFILE HEADER CARD ---
            BoxLayout:
                size_hint_y: None
                height: dp(110)
                padding: dp(15)
                spacing: dp(15)
                canvas.before:
                    Color:
                        rgba: 0.11, 0.12, 0.18, 1
                    RoundedRectangle:
                        size: self.size
                        pos: self.pos
                        radius: [dp(15)]
                        
                # Avatar Base (Pure Canvas Circle)
                Widget:
                    size_hint_x: None
                    width: dp(80)
                    canvas.before:
                        Color:
                            rgba: 0.40, 0.31, 0.85, 1  # ScholarBridge Purple
                        Ellipse:
                            size: self.size
                            pos: self.pos
                            
                # User Info & Badges
                BoxLayout:
                    orientation: 'vertical'
                    spacing: dp(5)
                    
                    Label:
                        text: '[b]Juan Dela Cruz[/b]'
                        markup: True
                        font_size: sp(18)
                        text_size: self.size
                        halign: 'left'
                        valign: 'bottom'
                        
                    Label:
                        text: 'student@university.edu.ph'
                        font_size: sp(12)
                        color: 1, 1, 1, 0.5
                        text_size: self.size
                        halign: 'left'
                        valign: 'top'
                        
                    # Trust Badges Row
                    BoxLayout:
                        spacing: dp(10)
                        Label:
                            text: '✓ Verified Uni'
                            font_size: sp(10)
                            color: 0.40, 0.85, 0.50, 1 # Green
                            text_size: self.size
                            halign: 'left'
                            valign: 'center'
                        Label:
                            text: '★ 4.9 Rating'
                            font_size: sp(10)
                            color: 1, 0.8, 0.2, 1 # Gold
                            text_size: self.size
                            halign: 'left'
                            valign: 'center'

            # --- 2. MARKETPLACE LISTINGS SECTION ---
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(10)
                
                # Section Header
                BoxLayout:
                    size_hint_y: None
                    height: dp(30)
                    Label:
                        text: '[b]YOUR MARKETPLACE LISTINGS[/b]'
                        markup: True
                        font_size: sp(12)
                        color: 1, 1, 1, 0.5
                        text_size: self.size
                        halign: 'left'
                        valign: 'center'
                    Button:
                        text: '[b]+ Add[/b]'
                        markup: True
                        size_hint_x: None
                        width: dp(60)
                        background_color: 0,0,0,0
                        color: 0.65, 0.50, 1.0, 1
                        
                # Dynamic Items
                ProfileItemCard:
                    title: 'Digital Logic Textbook'
                    price: '₱1,250'
                    icon_color: 0.25, 0.75, 1.0, 1  # Blue icon
                    
                ProfileItemCard:
                    title: 'Arduino Starter Kit'
                    price: '₱850'
                    icon_color: 0.25, 0.75, 1.0, 1

            # --- 3. FREELANCE SERVICES SECTION ---
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(10)
                
                # Section Header
                BoxLayout:
                    size_hint_y: None
                    height: dp(30)
                    Label:
                        text: '[b]YOUR FREELANCE SERVICES[/b]'
                        markup: True
                        font_size: sp(12)
                        color: 1, 1, 1, 0.5
                        text_size: self.size
                        halign: 'left'
                        valign: 'center'
                    Button:
                        text: '[b]+ Add[/b]'
                        markup: True
                        size_hint_x: None
                        width: dp(60)
                        background_color: 0,0,0,0
                        color: 0.65, 0.50, 1.0, 1
                        
                # Dynamic Items
                ProfileItemCard:
                    title: 'Godot Engine Tutoring'
                    price: '₱500/hr'
                    icon_color: 0.40, 0.31, 0.85, 1  # Purple icon
                    
                ProfileItemCard:
                    title: 'Python Scripting Help'
                    price: '₱400/hr'
                    icon_color: 0.40, 0.31, 0.85, 1

# -----------------------------------------------------
# REUSABLE COMPONENT: SETTINGS TOGGLE ROW
# -----------------------------------------------------
<SettingsToggleRow@BoxLayout>:
    title: 'Setting Name'
    # 'active_state' allows us to bind the switch from outside
    active_state: False  
    
    size_hint_y: None
    height: dp(60)
    padding: [dp(20), dp(10)]
    spacing: dp(15)
    canvas.before:
        Color:
            rgba: 0.11, 0.12, 0.18, 1  # Dark Card Background
        RoundedRectangle:
            size: self.size
            pos: self.pos
            radius: [dp(10)]
            
    Label:
        text: root.title
        font_size: sp(14)
        color: 1, 1, 1, 1
        text_size: self.size
        halign: 'left'
        valign: 'center'
        
    Switch:
        active: root.active_state
        size_hint_x: None
        width: dp(50)

# -----------------------------------------------------
# REUSABLE COMPONENT: SETTINGS BUTTON ROW
# -----------------------------------------------------
<SettingsButtonRow@ButtonBehavior+BoxLayout>:
    title: 'Action Name'
    title_color: 1, 1, 1, 1
    
    size_hint_y: None
    height: dp(60)
    padding: [dp(20), dp(10)]
    canvas.before:
        Color:
            rgba: 0.11, 0.12, 0.18, 1
        RoundedRectangle:
            size: self.size
            pos: self.pos
            radius: [dp(10)]
            
    Label:
        text: root.title
        font_size: sp(14)
        color: root.title_color
        text_size: self.size
        halign: 'left'
        valign: 'center'
        
    Label:
        text: '>'
        font_size: sp(18)
        color: 0.5, 0.5, 0.5, 1
        size_hint_x: None
        width: dp(20)
        text_size: self.size
        halign: 'right'
        valign: 'center'

# -----------------------------------------------------
# MAIN SETTINGS SCREEN
# -----------------------------------------------------
<SettingsInterface>:
    canvas.before:
        Color:
            rgba: 0.08, 0.09, 0.14, 1  # App Background
        Rectangle:
            size: self.size
            pos: self.pos

    ScrollView:
        do_scroll_x: False
        do_scroll_y: True
        
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height
            padding: dp(20)
            spacing: dp(25)
            
            # --- HEADER ---
            Label:
                text: '[b]Settings[/b]'
                markup: True
                font_size: sp(24)
                size_hint_y: None
                height: dp(40)
                text_size: self.size
                halign: 'left'
                valign: 'center'

            # --- NETWORK & STORAGE SECTION ---
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(10)
                
                Label:
                    text: 'NETWORK & STORAGE'
                    font_size: sp(12)
                    color: 1, 1, 1, 0.5
                    size_hint_y: None
                    height: dp(20)
                    text_size: self.size
                    halign: 'left'
                    valign: 'bottom'
                    
                SettingsToggleRow:
                    title: 'Force Offline Cache Mode'
                    # You can bind this to toggle the global variable!
                    
                SettingsButtonRow:
                    title: 'Clear Local JSON Database'
                    title_color: 0.85, 0.26, 0.33, 1  # Red text for destructive action
                    on_release: root.clear_local_cache()

            # --- SECURITY SECTION ---
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(10)
                
                Label:
                    text: 'SECURITY'
                    font_size: sp(12)
                    color: 1, 1, 1, 0.5
                    size_hint_y: None
                    height: dp(20)
                    text_size: self.size
                    halign: 'left'
                    valign: 'bottom'
                    
                SettingsButtonRow:
                    title: 'Manage Escrow PIN'
                    
                SettingsButtonRow:
                    title: 'Two-Factor Authentication'

            # --- ACCOUNT SECTION ---
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(10)
                
                Label:
                    text: 'ACCOUNT'
                    font_size: sp(12)
                    color: 1, 1, 1, 0.5
                    size_hint_y: None
                    height: dp(20)
                    text_size: self.size
                    halign: 'left'
                    valign: 'bottom'
                    
                SettingsButtonRow:
                    title: 'Log Out'
                    on_release: root.logout_user()
# -----------------------------------------------------------
# Polished Listing Card (Used for both Product and Service)
# -----------------------------------------------------------
<ActivityTile>:
    size_hint_y: None
    height: dp(70)
    padding: dp(12)
    spacing: dp(15)
    canvas.before:
        Color:
            rgba: 0.11, 0.12, 0.16, 1  # Dark card background
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(12)]
            
    # --- 1. Left Icon Box ---
    AnchorLayout:
        size_hint_x: None
        width: dp(45)
        canvas.before:
            Color:
                rgba: root.icon_bg_color
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(10)]
        Image:
            source: root.icon_source
            size_hint: 0.5, 0.5 # Scales the image down so it fits nicely inside the rounded box
            allow_stretch: True
            keep_ratio: True
                
    # --- 2. Middle Text (Title & Description) ---
    BoxLayout:
        orientation: 'vertical'
        spacing: dp(2)
        Label:
            text: f"[b]{root.activity_type}[/b]"
            markup: True
            font_size: sp(15)
            color: 1, 1, 1, 1
            text_size: self.size
            halign: 'left'
            valign: 'bottom'
        Label:
            text: root.item_title
            font_size: sp(13)
            color: 0.5, 0.5, 0.5, 1
            text_size: self.size
            halign: 'left'
            valign: 'top'
            shorten: True
            shorten_from: 'right'
            
    # --- 3. Right Text (Amount & Time) ---
    BoxLayout:
        orientation: 'vertical'
        size_hint_x: None
        width: dp(80)
        spacing: dp(2)
        Label:
            text: f"[b]{root.amount}[/b]"
            markup: True
            font_size: sp(15)
            color: root.text_color
            text_size: self.size
            halign: 'right'
            valign: 'bottom'
        Label:
            text: root.time_ago
            font_size: sp(12)
            color: 0.5, 0.5, 0.5, 1
            text_size: self.size
            halign: 'right'
            valign: 'top'
<DynamicProduct>:
    size_hint_y: None
    height: dp(110)
    padding: dp(15)
    spacing: dp(15)
    # Background click animation
    canvas.before:
        Color:
            rgba: (0.15, 0.16, 0.22, 1) if self.state == 'normal' else (0.20, 0.21, 0.28, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(15)]
            
    # Avatar Box
    FloatLayout:
        size_hint_x: None
        width: dp(50)
        canvas.before:
            Color:
                rgba: 0.43, 0.33, 0.85, 1
            Ellipse:
                pos: [self.center_x - dp(25), self.center_y - dp(25)]
                size: dp(50), dp(50)
        Label:
			pos_hint: {'center_x': 0.5, 'center_y': 0.5}
            text: f'[b]{root.initial}[/b]'
            markup: True
            font_size: sp(16)
            
    # Details Box
    BoxLayout:
        orientation: 'vertical'
        spacing: dp(2)
        Label:
            text: f'[b]{root.title}[/b]'
            markup: True
            font_size: sp(15)
            text_size: self.size
            halign: 'left'
            valign: 'bottom'
            color: 1, 1, 1, 1
        Label:
            text: f'{root.product_type} • {root.condition}'
            font_size: sp(12)
            color: 0.6, 0.6, 0.6, 1
            text_size: self.size
            halign: 'left'
            valign: 'middle'
        Label:
            text: f'By {root.fullname}'
            font_size: sp(11)
            color: 0.4, 0.4, 0.4, 1
            text_size: self.size
            halign: 'left'
            valign: 'top'
            
    # Price Box
    BoxLayout:
        size_hint_x: None
        width: dp(70)
        orientation: 'vertical'
        Label:
            text: f'[b]₱{root.price:,.2f}[/b]'
            markup: True
            font_size: sp(14)
            color: 0.43, 0.33, 0.85, 1
            text_size: self.size
            halign: 'right'
            valign: 'middle'
<DynamicActivity>:
	canvas.before:
		Color:
			rgba: 0.15, 0.17, 0.23, 0.5
		RoundedRectangle:
			size: self.size
			pos: self.pos

<DynamicService>:
	size_hint: 1, 0.2
	canvas.before:
		Color:
			rgba: 0.15, 0.17, 0.23, 0.5
		RoundedRectangle:
			size: self.size
			pos: self.pos					

<TransactionTile>:
    size_hint_y: None
    height: dp(65)
    padding: dp(15)
    spacing: dp(10)
    canvas.before:
        Color:
            rgba: 1, 1, 1, 0.05
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(12)]
    BoxLayout:
        orientation: 'vertical'
        Label:
            id: desc_label       # Using ID instead of root.property
            text: ''
            markup: True
            font_size: sp(14)
            text_size: self.size
            halign: 'left'
            valign: 'bottom'
        Label:
            id: date_label       # Using ID instead of root.property
            text: ''
            color: 0.6, 0.6, 0.6, 1
            font_size: sp(11)
            text_size: self.size
            halign: 'left'
            valign: 'top'
    Label:
        id: amount_label         # Using ID instead of root.property
        text: ''
        markup: True
        font_size: sp(15)
        bold: True
        size_hint_x: None
        width: dp(90)
        text_size: self.size
        halign: 'right'
        valign: 'middle'
