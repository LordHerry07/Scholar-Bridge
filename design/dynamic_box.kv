# -----------------------------------------------------------
# Polished Listing Card (Used for both Product and Service)
# -----------------------------------------------------------
<ActivityTile>:
    size_hint_y: None
    height: dp(70)
    padding: dp(12)
    spacing: dp(15)
    canvas.before:
        Color:
            rgba: 0.11, 0.12, 0.16, 1  # Dark card background
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(12)]
            
    # --- 1. Left Icon Box ---
    AnchorLayout:
        size_hint_x: None
        width: dp(45)
        canvas.before:
            Color:
                rgba: root.icon_bg_color
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(10)]
        Image:
            source: root.icon_source
            size_hint: 0.5, 0.5 # Scales the image down so it fits nicely inside the rounded box
            allow_stretch: True
            keep_ratio: True
                
    # --- 2. Middle Text (Title & Description) ---
    BoxLayout:
        orientation: 'vertical'
        spacing: dp(2)
        Label:
            text: f"[b]{root.activity_type}[/b]"
            markup: True
            font_size: sp(15)
            color: 1, 1, 1, 1
            text_size: self.size
            halign: 'left'
            valign: 'bottom'
        Label:
            text: root.item_title
            font_size: sp(13)
            color: 0.5, 0.5, 0.5, 1
            text_size: self.size
            halign: 'left'
            valign: 'top'
            shorten: True
            shorten_from: 'right'
            
    # --- 3. Right Text (Amount & Time) ---
    BoxLayout:
        orientation: 'vertical'
        size_hint_x: None
        width: dp(80)
        spacing: dp(2)
        Label:
            text: f"[b]{root.amount}[/b]"
            markup: True
            font_size: sp(15)
            color: root.text_color
            text_size: self.size
            halign: 'right'
            valign: 'bottom'
        Label:
            text: root.time_ago
            font_size: sp(12)
            color: 0.5, 0.5, 0.5, 1
            text_size: self.size
            halign: 'right'
            valign: 'top'
<DynamicProduct>:
    size_hint_y: None
    height: dp(110)
    padding: dp(15)
    spacing: dp(15)
    # Background click animation
    canvas.before:
        Color:
            rgba: (0.15, 0.16, 0.22, 1) if self.state == 'normal' else (0.20, 0.21, 0.28, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(15)]
            
    # Avatar Box
    FloatLayout:
        size_hint_x: None
        width: dp(50)
        canvas.before:
            Color:
                rgba: 0.43, 0.33, 0.85, 1
            Ellipse:
                pos: [self.center_x - dp(25), self.center_y - dp(25)]
                size: dp(50), dp(50)
        Label:
			pos_hint: {'center_x': 0.5, 'center_y': 0.5}
            text: f'[b]{root.initial}[/b]'
            markup: True
            font_size: sp(16)
            
    # Details Box
    BoxLayout:
        orientation: 'vertical'
        spacing: dp(2)
        Label:
            text: f'[b]{root.title}[/b]'
            markup: True
            font_size: sp(15)
            text_size: self.size
            halign: 'left'
            valign: 'bottom'
            color: 1, 1, 1, 1
        Label:
            text: f'{root.product_type} • {root.condition}'
            font_size: sp(12)
            color: 0.6, 0.6, 0.6, 1
            text_size: self.size
            halign: 'left'
            valign: 'middle'
        Label:
            text: f'By {root.fullname}'
            font_size: sp(11)
            color: 0.4, 0.4, 0.4, 1
            text_size: self.size
            halign: 'left'
            valign: 'top'
            
    # Price Box
    BoxLayout:
        size_hint_x: None
        width: dp(70)
        orientation: 'vertical'
        Label:
            text: f'[b]₱{root.price:,.2f}[/b]'
            markup: True
            font_size: sp(14)
            color: 0.43, 0.33, 0.85, 1
            text_size: self.size
            halign: 'right'
            valign: 'middle'
<DynamicActivity>:
	canvas.before:
		Color:
			rgba: 0.15, 0.17, 0.23, 0.5
		RoundedRectangle:
			size: self.size
			pos: self.pos

<DynamicService>:
	size_hint: 1, 0.2
	canvas.before:
		Color:
			rgba: 0.15, 0.17, 0.23, 0.5
		RoundedRectangle:
			size: self.size
			pos: self.pos					

<TransactionTile>:
    size_hint_y: None
    height: dp(65)
    padding: dp(15)
    spacing: dp(10)
    canvas.before:
        Color:
            rgba: 1, 1, 1, 0.05
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(12)]
    BoxLayout:
        orientation: 'vertical'
        Label:
            id: desc_label       # Using ID instead of root.property
            text: ''
            markup: True
            font_size: sp(14)
            text_size: self.size
            halign: 'left'
            valign: 'bottom'
        Label:
            id: date_label       # Using ID instead of root.property
            text: ''
            color: 0.6, 0.6, 0.6, 1
            font_size: sp(11)
            text_size: self.size
            halign: 'left'
            valign: 'top'
    Label:
        id: amount_label         # Using ID instead of root.property
        text: ''
        markup: True
        font_size: sp(15)
        bold: True
        size_hint_x: None
        width: dp(90)
        text_size: self.size
        halign: 'right'
        valign: 'middle'
