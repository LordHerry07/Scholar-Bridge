#-----------------------------------------------------------#
# GLOBAL OFFLINE BANNER
#-----------------------------------------------------------#
<OfflineBanner>:
    canvas.before:
        Color:
            rgba: 0.85, 0.26, 0.33, 0.95  # Slightly transparent neon red
        Rectangle:
            pos: self.pos
            size: self.size
            
    # Centered Warning Text
    Label:
        text: '⚠ You are offline. Viewing cached data.'
        font_size: sp(13)
        color: 1, 1, 1, 1
        bold: True

<ServerSelectorModal>:
    size_hint: 0.85, None
    height: dp(230)
    background: '' 
    background_color: 0, 0, 0, 0 
    
    BoxLayout:
        orientation: 'vertical'
        padding: dp(25)
        spacing: dp(15)
        canvas.before:
            Color:
                rgba: 0.11, 0.12, 0.16, 1  
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(20)]
                
        Label:
            text: '[b]Server Configuration[/b]'
            markup: True
            font_size: sp(18)
            size_hint_y: None
            height: dp(30)
            text_size: self.size
            halign: 'left'
            valign: 'middle'
            
        Label:
            text: 'Enter the IPv4 address and port of your active ScholarBridge host.'
            color: 0.6, 0.6, 0.6, 1
            font_size: sp(12)
            size_hint_y: None
            height: dp(30)
            text_size: self.size
            halign: 'left'
            valign: 'top'
            
        TextInput:
            id: server_ip_input
            hint_text: 'e.g. 192.168.1.5:5000'
            size_hint_y: None
            height: dp(50)
            background_normal: ''
            background_color: 0.15, 0.16, 0.22, 1
            foreground_color: 1, 1, 1, 1
            hint_text_color: 0.5, 0.5, 0.5, 1
            cursor_color: 0.43, 0.33, 0.85, 1
            multiline: False
            padding: [dp(15), (self.height - self.line_height) / 2]
            canvas.after:
                Color:
                    rgba: 1, 1, 1, 0.2
                Line:
                    rounded_rectangle: [self.x, self.y, self.width, self.height, dp(8)]
                    width: dp(1)

        # --- UNIFIED BUTTON ROW ---
        BoxLayout:
            size_hint_y: None
            height: dp(45)
            spacing: dp(10)
            
            # Left Button: Work Offline
            Button:
                text: '[b]Work Offline[/b]'
                markup: True
                background_color: 0,0,0,0
                canvas.before:
                    Color:
                        rgba: 0.15, 0.16, 0.22, 1 # Dark Gray Theme
                    RoundedRectangle:
                        size: self.size
                        pos: self.pos
                        radius: [dp(10)]
                on_release: root.set_offline_mode()
                
            # Right Button: Connect Online
            Button:
                text: '[b]Connect[/b]'
                markup: True
                background_color: 0,0,0,0
                canvas.before:
                    Color:
                        rgba: 0.43, 0.33, 0.85, 1 # Purple Accent Theme
                    RoundedRectangle:
                        size: self.size
                        pos: self.pos
                        radius: [dp(10)]
                on_release:
                    root.save_server()
                    root.set_online_mode(server_ip_input.text)

<NotificationModal>:
    size_hint: 0.8, None
    height: dp(200)
    background: ''
    background_color: 0, 0, 0, 0
    
    BoxLayout:
        orientation: 'vertical'
        padding: dp(20)
        spacing: dp(15)
        canvas.before:
            Color:
                rgba: 0.15, 0.16, 0.22, 1
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(15)]
                
        Label:
            id: notif_title
            text: '[b]Notice[/b]'
            markup: True
            font_size: sp(18)
            size_hint_y: None
            height: dp(30)
            color: 1, 1, 1, 1
            
        Label:
            id: notif_message
            text: 'Message goes here.'
            font_size: sp(14)
            color: 0.8, 0.8, 0.8, 1
            text_size: self.width, None
            halign: 'center'
            valign: 'middle'
            
        Button:
            text: '[b]OK[/b]'
            markup: True
            size_hint_y: None
            height: dp(45)
            background_color: 0,0,0,0
            canvas.before:
                Color:
                    rgba: 0.43, 0.33, 0.85, 1
                RoundedRectangle:
                    size: self.size
                    pos: self.pos
                    radius: [dp(22)]
            on_release: root.dismiss()
<ReviewModal>:
    size_hint: 0.85, 0.6
    background: '' 
    background_color: 0, 0, 0, 0 
    
    BoxLayout:
        orientation: 'vertical'
        padding: dp(25)
        spacing: dp(15)
        canvas.before:
            Color:
                rgba: 0.11, 0.12, 0.16, 1  
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(20)]
                
        Label:
            text: '[b]Rate your transaction[/b]'
            markup: True
            font_size: sp(20)
            size_hint_y: None
            height: dp(30)
            
        Label:
            text: f'How was your experience with {root.seller_name}?'
            color: 0.6, 0.6, 0.6, 1
            font_size: sp(14)
            size_hint_y: None
            height: dp(20)
            
        # Star Rating Buttons
        BoxLayout:
            size_hint_y: None
            height: dp(50)
            spacing: dp(10)
            pos_hint: {'center_x': 0.5}
            size_hint_x: None
            width: self.minimum_width
            
            Button:
                text: '⭐' if root.current_rating >= 1 else '☆'
                font_size: sp(30)
                background_color: 0,0,0,0
                size_hint_x: None
                width: dp(40)
                on_release: root.current_rating = 1
            Button:
                text: '⭐' if root.current_rating >= 2 else '☆'
                font_size: sp(30)
                background_color: 0,0,0,0
                size_hint_x: None
                width: dp(40)
                on_release: root.current_rating = 2
            Button:
                text: '⭐' if root.current_rating >= 3 else '☆'
                font_size: sp(30)
                background_color: 0,0,0,0
                size_hint_x: None
                width: dp(40)
                on_release: root.current_rating = 3
            Button:
                text: '⭐' if root.current_rating >= 4 else '☆'
                font_size: sp(30)
                background_color: 0,0,0,0
                size_hint_x: None
                width: dp(40)
                on_release: root.current_rating = 4
            Button:
                text: '⭐' if root.current_rating >= 5 else '☆'
                font_size: sp(30)
                background_color: 0,0,0,0
                size_hint_x: None
                width: dp(40)
                on_release: root.current_rating = 5

        TextInput:
            id: review_comment
            hint_text: 'Leave a comment (optional)...'
            background_color: 1, 1, 1, 0.05
            foreground_color: 1, 1, 1, 1
            hint_text_color: 1, 1, 1, 0.3
            cursor_color: 0.42, 0.35, 0.88, 1
            padding: [dp(15), dp(15)]
            canvas.before:
                Color:
                    rgba: 1, 1, 1, 0.2
                Line:
                    rounded_rectangle: [self.x, self.y, self.width, self.height, dp(8)]
                    width: dp(1)

        # Submit Button
        Button:
            text: '[b]Submit Review[/b]'
            markup: True
            size_hint_y: None
            height: dp(50)
            background_color: 0,0,0,0
            canvas.before:
                Color:
                    rgba: (0.42, 0.35, 0.88, 1) if self.state == 'normal' else (0.3, 0.25, 0.7, 1)
                RoundedRectangle:
                    size: self.size
                    pos: self.pos
                    radius: [dp(25)]
            on_release: root.submit()
<PublicProfileModal>:
    size_hint: 0.9, 0.85
    background: '' 
    background_color: 0, 0, 0, 0 
    
    BoxLayout:
        orientation: 'vertical'
        padding: dp(20)
        spacing: dp(15)
        canvas.before:
            Color:
                rgba: 0.11, 0.12, 0.16, 1  
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(20)]
                
        # Header Block
        BoxLayout:
            size_hint_y: None
            height: dp(80)
            spacing: dp(15)
            
            # Avatar
            FloatLayout:
                size_hint_x: None
                width: dp(60)
                canvas.before:
                    Color:
                        rgba: 0.43, 0.33, 0.85, 1
                    Ellipse:
                        pos: [self.center_x - dp(30), self.center_y - dp(30)]
                        size: dp(60), dp(60)
                Label:
                    text: f'[b]{root.initial}[/b]'
                    markup: True
                    font_size: sp(20)
                    pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                    
            # Name & Stats
            BoxLayout:
                orientation: 'vertical'
                padding: [0, dp(10), 0, dp(10)]
                Label:
                    id: profile_name
                    text: 'Loading...'
                    markup: True
                    font_size: sp(18)
                    text_size: self.size
                    halign: 'left'
                    valign: 'bottom'
                Label:
                    id: profile_stats
                    text: '⭐ -- Rating • -- Active Listings'
                    color: 0.6, 0.6, 0.6, 1
                    font_size: sp(13)
                    text_size: self.size
                    halign: 'left'
                    valign: 'top'
                    
        # Divider Line
        Widget:
            size_hint_y: None
            height: dp(1)
            canvas.before:
                Color:
                    rgba: 1, 1, 1, 0.1
                Rectangle:
                    pos: self.pos
                    size: self.size
                    
        Label:
            text: '[b]Active Listings[/b]'
            markup: True
            size_hint_y: None
            height: dp(30)
            font_size: sp(16)
            text_size: self.size
            halign: 'left'
            valign: 'middle'
            
        # Scrollable Listings
        ScrollView:
            do_scroll: False, True
            bar_width: 0
            BoxLayout:
                id: active_listings
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(10)
<ProductDetailsModal>:
    size_hint: 0.85, 0.65
    background_color: 0, 0, 0, 0.6
    background: '' # Removes default Kivy modal background
    
    BoxLayout:
        orientation: 'vertical'
        padding: dp(20)
        spacing: dp(15)
        canvas.before:
            Color:
                rgba: 0.11, 0.12, 0.16, 1  # Dark modal background
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(20)]
                
        # Header: Title & Price
        BoxLayout:
            size_hint_y: None
            height: dp(60)
            orientation: 'vertical'
            Label:
                text: f'[b]{root.title}[/b]'
                markup: True
                font_size: sp(18)
                text_size: self.size
                halign: 'left'
                valign: 'bottom'
            Label:
                text: f'[color=#6b59e0]₱{root.price:,.2f}[/color] • Condition: {root.condition}'
                markup: True
                font_size: sp(14)
                color: 0.6, 0.6, 0.6, 1
                text_size: self.size
                halign: 'left'
                valign: 'top'

        # Scrollable Description
        ScrollView:
            do_scroll: False, True
            bar_width: dp(4)
            Label:
                text: root.description
                size_hint_y: None
                height: self.texture_size[1]
                text_size: self.width, None
                font_size: sp(14)
                color: 0.8, 0.8, 0.8, 1
                halign: 'left'
                valign: 'top'

        # Seller Info Block
        BoxLayout:
            size_hint_y: None
            height: dp(50)
            spacing: dp(10)
            canvas.before:
                Color:
                    rgba: 1, 1, 1, 0.05
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(10)]
            # Avatar
            FloatLayout:
                size_hint_x: None
                width: dp(50)
                canvas.before:
                    Color:
                        rgba: 0.43, 0.33, 0.85, 1
                    Ellipse:
                        pos: [self.center_x - dp(17.5), self.center_y - dp(17.5)]
                        size: dp(35), dp(35)
                Label:
                    text: f'[b]{root.initial}[/b]'
                    markup: True
                    font_size: sp(14)
            # Name & Status
            BoxLayout:
                orientation: 'vertical'
                padding: [0, dp(8), 0, dp(8)]
                Label:
                    text: f'[b]{root.fullname}[/b]'
                    markup: True
                    font_size: sp(14)
                    text_size: self.size
                    halign: 'left'
                Label:
                    text: '● Online Now'
                    color: 0.16, 0.67, 0.38, 1
                    font_size: sp(11)
                    text_size: self.size
                    halign: 'left'

        # Action Buttons
        BoxLayout:
            size_hint_y: None
            height: dp(45)
            spacing: dp(10)
            
            # Interested (Heart) Button
            ToggleButton:
                text: '❤ View Profile'
                size_hint_x: 0.4
                font_size: sp(13)
                background_color: 0,0,0,0
                color: (1, 0.3, 0.3, 1) if self.state == 'down' else (1, 1, 1, 0.5)
                on_release: root.view_profile()
                canvas.before:
                    Color:
                        rgba: (1, 0.3, 0.3, 0.2) if self.state == 'down' else (1, 1, 1, 0.1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(10)]
                        
            # Chat Now Button
            Button:
                text: '[b]Chat Now[/b]'
                markup: True
                size_hint_x: 0.6
                font_size: sp(14)
                background_color: 0,0,0,0
                on_release: root.go_to_chat()
                canvas.before:
                    Color:
                        rgba: 0.43, 0.33, 0.85, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(10)]

        # View Profile Button (Faint text button at bottom)
        # Secure Buy Button
        Button:
            size_hint_y: None
            height: dp(45)
            text: '🔒 Buy Securely via Escrow'
            font_size: sp(14)
            bold: True
            color: 1, 1, 1, 1
            background_color: 0,0,0,0
            on_release: root.buy_item()
            canvas.before:
                Color:
                    rgba: 0.16, 0.67, 0.38, 1  # A trustworthy green!
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(10)]
