#:import main_interface core.main_interface
#:import os os
<Interface>:
	id: interface
    MainInterface:
		name: "main"
		id: main
	StartInterface:
		name: "start"
		id: start

<MainInterface>:
    canvas.before:
        Color:
            rgba: 0.08, 0.09, 0.14, 1
        Rectangle:
            size: root.size
            pos: root.pos
    BoxLayout:
        orientation: 'vertical'
        BoxLayout:
            size_hint_y: 0.1
            orientation: 'vertical'
            spacing: dp(10)
            
            # --- UPDATED GLOBAL HEADER ---
            BoxLayout:
                size_hint: 0.9, 0.1
                pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                orientation: 'horizontal'
                
                # Left Side: Vertically Stacked Labels
                BoxLayout:
                    orientation: 'vertical'
                    Label:
                        id: label1
                        text: '[b]DASHBOARD[/b]'
                        text_size: self.size
                        font_size: dp(19)
                        markup: True
                        valign: 'bottom'
                        halign: 'left'
                    Label:
                        id: label2
                        text: 'you activity overview'
                        color: 1,1,1,0.5
                        text_size: self.size
                        valign: 'top'
                        halign: 'left'
                        
                # Right Side: Global Back Button
                NavBackButton:
                    id: back_btn
                    opacity: 0     
                    disabled: True 
                    pos_hint: {'center_y': 0.5}
                    on_release:
                        screenmanager.get_screen('info').children[0].ids.screenmanager.current = 'menu'
                        label1.text = '[b]MENU[/b]'
                        label2.text = 'manage your account'
                        self.opacity = 0
                        self.disabled = True
#-------------------------------------------------------------#

#-------------------------------------------------------------#
        ScreenManager:
            id: screenmanager
            size_hint: 0.9, 0.95
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
            Screen:
                name: 'dashboard'
                Dashboard:
            Screen:
                name: 'product'
                Product:
            Screen:
                name: 'sell'
                Sell:
            Screen:
                name: 'service'
                Service:
            Screen:
                name: 'info'
                Status:
#-------------------------------------------------------------#

#-------------------------------------------------------------#
        BoxLayout:
            size_hint: 0.98, 0.1
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
            orientation: 'horizontal'
            canvas.before:
                Color:
                    rgba: 1,1,1,0.1
                Rectangle:
                    size: self.size[0] + dp(50), self.size[1] + dp(2)
                    pos: self.pos[0] - dp(25), self.pos[1] - dp(1)   
                Color:
                    rgba: 0.11, 0.12, 0.18, 1
                Rectangle:
                    size: self.size[0] + dp(48), self.size[1] 
                    pos: self.pos[0] - dp(24), self.pos[1]
#-------------------------------------------------------------#
            BoxLayout:
                orientation: 'vertical'
                pos_hint: {'center_x': 0.5, 'center_y': 0.35}
                Image:
                    size_hint: 0.5, 0.5
                    pos_hint: {'center_x': 0.5, 'center_y': 0}
                    source: 'assets/dashboard_down.png'
                    ToggleButton:
                        id: dashboard
                        size: self.parent.parent.size
                        pos: self.parent.parent.pos
                        group: "footer"
                        background_color: 0,0,0,0
                        disabled: True if self.state == 'down' else False
                        state: 'down'
                        on_state:
                            self.parent.source = 'assets/dashboard_normal.png' if self.state == 'normal' else 'assets/dashboard_down.png'
                            if self.state == 'down': screenmanager.current = 'dashboard'
                            if self.state == 'down': screenmanager.get_screen('dashboard').children[0].load_stats()
                            if self.state == 'down': label1.text = '[b]DASHBOARD[/b]'
                            if self.state == 'down': label2.text = 'you activity overview'      
                            if self.state == 'down': back_btn.opacity = 0
                            if self.state == 'down': back_btn.disabled = True
                Label:   
                    pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                    size_hint_y: 0.5
                    text: "[b]DASHBOARD[/b]"
                    color: (1,1,1,1) if dashboard.state == 'normal' else (0.20, 0.11, 0.44, 1)
                    font_size: dp(10)
                    text_size: self.size
                    markup: True
                    halign: 'center'
                    valign: 'top'
#-------------------------------------------------------------#
            BoxLayout:
                orientation: 'vertical'
                pos_hint: {'center_x': 0.5, 'center_y': 0.35}
                Image:
                    size_hint: 0.5, 0.5
                    pos_hint: {'center_x': 0.5, 'center_y': 0}
                    source: 'assets/product_normal.png'
                    ToggleButton:
                        id: product
                        size: self.parent.parent.size
                        pos: self.parent.parent.pos
                        group: "footer"
                        background_color: 0,0,0,0
                        disabled: True if self.state == 'down' else False
                        on_state:
                            self.parent.source = 'assets/product_normal.png' if self.state == 'normal' else 'assets/product_down.png'
                            if self.state == 'down': screenmanager.current = 'product'
                            if self.state == 'down': screenmanager.get_screen('product').children[0].get_products(0)
                            if self.state == 'down': label1.text = '[b]PRODUCT[/b]'
                            if self.state == 'down': label2.text = 'textbooks, notes & materials'
                            if self.state == 'down': back_btn.opacity = 0
                            if self.state == 'down': back_btn.disabled = True
                Label:
                    pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                    size_hint_y: 0.5
                    text: "[b]PRODUCT[/b]"
                    font_size: dp(10)
                    color: (1,1,1,1) if product.state == 'normal' else (0.20, 0.11, 0.44, 1)
                    text_size: self.size
                    markup: True
                    halign: 'center'
                    valign: 'top'
#-------------------------------------------------------------#
            BoxLayout:
                orientation: 'vertical'
                pos_hint: {'center_x': 0.5, 'center_y': 0.6}
                Image:
                    size_hint: 0.5, 0.5
                    pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                    source: 'assets/sell.png'
                    canvas.before:
                        Color:
                            rgba: 0.4, 0.31, 0.85, 1
                        Ellipse:
                            size: self.parent.size
                            pos: self.pos[0] - self.size[0] // 2, self.pos[1] - self.size[1] // 2
                    ToggleButton:
                        id: sell
                        size: self.parent.parent.size
                        pos: self.parent.parent.pos
                        group: "footer"
                        background_color: 0,0,0,0
                        disabled: True if self.state == 'down' else False
                        on_state:
                            if self.state == 'down': screenmanager.current = 'sell'
                            if self.state == 'down': label1.text = '[b]CREATE LISTING[/b]'
                            if self.state == 'down': label2.text = 'publish your products & services'
                            if self.state == 'down': back_btn.opacity = 0
                            if self.state == 'down': back_btn.disabled = True
                Label:
                    pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                    size_hint_y: 0.5
                    text: "[b]SELL[/b]"
                    color: (1,1,1,1) if sell.state == 'normal' else (0.20, 0.11, 0.44, 1)
                    font_size: dp(10)
                    text_size: self.size
                    markup: True
                    halign: 'center'
                    valign: 'bottom'
#-------------------------------------------------------------#
            BoxLayout:
                orientation: 'vertical'
                pos_hint: {'center_x': 0.5, 'center_y': 0.35}
                Image:
                    size_hint: 0.5, 0.5
                    pos_hint: {'center_x': 0.5, 'center_y': 0}
                    source: 'assets/service_normal.png'
                    ToggleButton:
                        id: service
                        size: self.parent.parent.size
                        pos: self.parent.parent.pos
                        group: "footer"
                        background_color: 0,0,0,0
                        disabled: True if self.state == 'down' else False
                        on_state:
                            self.parent.source = 'assets/service_normal.png' if self.state == 'normal' else 'assets/service_down.png'
                            if self.state == 'down': screenmanager.current = 'service'
                            if self.state == 'down': screenmanager.get_screen('service').children[0].get_services(0)
                            if self.state == 'down': label1.text = '[b]SERVICE[/b]'
                            if self.state == 'down': label2.text = 'tutoring, review & freelance help'
                            if self.state == 'down': back_btn.opacity = 0
                            if self.state == 'down': back_btn.disabled = True
                Label:
                    pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                    size_hint_y: 0.5
                    text: "[b]SERVICE[/b]"
                    color: (1,1,1,1) if service.state == 'normal' else (0.20, 0.11, 0.44, 1)
                    font_size: dp(10)
                    text_size: self.size
                    markup: True
                    halign: 'center'
                    valign: 'top'
#-------------------------------------------------------------#
            BoxLayout:
                orientation: 'vertical'
                pos_hint: {'center_x': 0.5, 'center_y': 0.35}
                Image:
                    size_hint: 0.5, 0.5
                    pos_hint: {'center_x': 0.5, 'center_y': 0}
                    source: 'assets/person_normal.png'
                    ToggleButton:
                        id: info
                        size: self.parent.parent.size
                        pos: self.parent.parent.pos
                        group: "footer"
                        background_color: 0,0,0,0
                        disabled: True if self.state == 'down' else False
                        on_state:
                            self.parent.source = 'assets/person_normal.png' if self.state == 'normal' else 'assets/person_down.png'
                            if self.state == 'down': screenmanager.current = 'info'
                            if self.state == 'down': screenmanager.get_screen('info').children[0].ids.screenmanager.current = 'menu'
                            if self.state == 'down': label1.text = '[b]MENU[/b]'
                            if self.state == 'down': label2.text = 'manage your account'
                            if self.state == 'down': back_btn.opacity = 0
                            if self.state == 'down': back_btn.disabled = True
                Label:
                    pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                    size_hint_y: 0.5
                    text: "[b]STATUS[/b]"
                    color: (1,1,1,1) if info.state == 'normal' else (0.20, 0.11, 0.44, 1)
                    font_size: dp(10)
                    text_size: self.size
                    markup: True
                    halign: 'center'
                    valign: 'top'
#------------------------------------------------------------#
#DASHBOARD                   
#-----------------------------------------------------------#
<Dashboard>:
    ScrollView:
        size: root.size
        pos: root.pos
        do_scroll: False, True
        bar_width: 0
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: 1.5
            spacing: dp(10)
#-------------------------------------------------------------#
# 0
#-------------------------------------------------------------#
            GridLayout:
                rows: 2
                cols: 2
                spacing: dp(10)
#1------------------------------------------------------------#
                BoxLayout:
                    orientation: 'vertical'
                    spacing: dp(5)
                    canvas.before:
                        Color:
                            rgba: 0.11, 0.12, 0.18, 1
                        RoundedRectangle:
                            size: self.size
                            pos: self.pos
                            radius: [10]
                    Label:
                        size_hint_y: 0.1
                    BoxLayout:
                        orientation: 'horizontal'
                        Label:
                            size_hint_x: 0.1
                        Label:
                            size_hint_x: 0.3
                            text: '₱'
                            text_size: self.size
                            color: 0.4, 0.31, 0.85, 1
                            halign: 'center'
                            valign: 'center'
                            canvas.before:
                                Color:
                                    rgba: 0.15, 0.17, 0.23, 0.5
                                RoundedRectangle:
                                    size: self.size
                                    pos: self.pos
                        Label:
                            size_hint_x: 0.1
                        Label:
                            size_hint_x: 0.3
                            text: '+12%'
                            font_size: dp(12)
                            text_size: self.size
                            color: 0.16, 0.59, 0.33, 1
                            halign: 'center'
                            valign: 'center'
                            canvas.before:
                                Color:
                                    rgba: 0.15, 0.17, 0.23, 0.5
                                RoundedRectangle:
                                    size: self.size
                                    pos: self.pos
                        Label:
                            size_hint_x: 0.1
                    Label:
                        id: earnings_label
                        text: '[b]₱0.00[/b]'
                        font_size: dp(16)
                        text_size: self.size
                        markup: True
                        halign: 'center'
                    Label:
                        text: 'Total Earnings'
                        font_size: dp(10)
                        text_size: self.size
                        halign: 'center'
                        valign: 'top'
#2------------------------------------------------------------#
                BoxLayout:
                    orientation: 'vertical'
                    spacing: dp(5)
                    canvas.before:
                        Color:
                            rgba: 0.11, 0.12, 0.18, 1
                        RoundedRectangle:
                            size: self.size
                            pos: self.pos
                            radius: [10]
                    Label:
                        size_hint_y: 0.1
                    BoxLayout:
                        orientation: 'horizontal'
                        Label:
                            size_hint_x: 0.1
                        Image:
                            source: 'assets/product_down.png'
                            size_hint_x: 0.3
                          
                            canvas.before:
                                Color:
                                    rgba: 0.15, 0.17, 0.23, 0.5
                                RoundedRectangle:
                                    size: self.size
                                    pos: self.pos
                        Label:
                            size_hint_x: 0.1
                        Label:
                            size_hint_x: 0.3
                            text: '+2'
                            font_size: dp(12)
                            text_size: self.size
                            color: 0.16, 0.59, 0.33, 1
                            halign: 'center'
                            valign: 'center'
                            canvas.before:
                                Color:
                                    rgba: 0.15, 0.17, 0.23, 0.5
                                RoundedRectangle:
                                    size: self.size
                                    pos: self.pos
                        Label:
                            size_hint_x: 0.1
                    Label:
                        id: active_listings_label
                        text: '[b]0[/b]'
                        font_size: dp(16)
                        text_size: self.size
                        markup: True
                        halign: 'center'
                    Label:
                        text: 'Active Listing'
                        font_size: dp(10)
                        text_size: self.size
                        halign: 'center'
                        valign: 'top'
#3------------------------------------------------------------#
                BoxLayout:
                    orientation: 'vertical'
                    spacing: dp(5)
                    canvas.before:
                        Color:
                            rgba: 0.11, 0.12, 0.18, 1
                        RoundedRectangle:
                            size: self.size
                            pos: self.pos
                            radius: [10]
                    Label:
                        size_hint_y: 0.1
                    BoxLayout:
                        orientation: 'horizontal'
                        Label:
                            size_hint_x: 0.1
                        Image:
                            source: 'assets/eye.png'
                            size_hint_x: 0.3
                            canvas.before:
                                Color:
                                    rgba: 0.15, 0.17, 0.23, 0.5
                                RoundedRectangle:
                                    size: self.size
                                    pos: self.pos
                        Label:
                            size_hint_x: 0.1
                        Label:
                            size_hint_x: 0.3
                            text: '+2'
                            font_size: dp(12)
                            text_size: self.size
                            color: 0.16, 0.59, 0.33, 1
                            halign: 'center'
                            valign: 'center'
                            canvas.before:
                                Color:
                                    rgba: 0.15, 0.17, 0.23, 0.5
                                RoundedRectangle:
                                    size: self.size
                                    pos: self.pos
                        Label:
                            size_hint_x: 0.1
                    Label:
                        text: '[b]5[/b]'
                        font_size: dp(16)
                        text_size: self.size
                        markup: True
                        halign: 'center'
                    Label:
                        text: 'Active Listing'
                        font_size: dp(10)
                        text_size: self.size
                        halign: 'center'
                        valign: 'top'
#4------------------------------------------------------------#
                BoxLayout:
                    orientation: 'vertical'
                    canvas.before:
                        Color:
                            rgba: 0.11, 0.12, 0.18, 1
                        RoundedRectangle:
                            size: self.size
                            pos: self.pos
                            radius: [10]
         
#5----------------------------------------------------------#
            BoxLayout:
                id: graph
                orientation: 'vertical'
                canvas.before:
                    Color:
                        rgba: 0.11, 0.12, 0.18, 1
                    RoundedRectangle:
                        size: self.size
                        pos: self.pos
                        radius: [10]
                Label:
                    size_hint_y: 0.05
                BoxLayout:
                    size_hint: 0.9, 0.2
                    pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                    spacing: dp(5)
                    orientation: 'horizontal'
                    BoxLayout:
                        orientation: 'horizontal'
                        Label:
                            text: '[b]EARNINGS[/b]'
                            markup: True
                            text_size: self.size
                            halign: 'left'
                            valign: 'center'
                        Image:
                            source: 'assets/bar_graph.png'
                            size_hint: None, 1
                            canvas.before:
                                Color:
                                    rgba: 0.15, 0.17, 0.23, 0.5
                                RoundedRectangle:
                                    size: self.size
                                    pos: self.pos
                         
                ScrollView:
                    size_hint: 0.9, 0.3
                    pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                    id: scroll
                    do_scroll_y: False
                    bar_width: 0
                    Widget:
                        id: chart
                        size_hint_x: None
                        height: root.height
                        width: 100
                        canvas:
                            Color:
                                rgba: 0.11, 0.12, 0.18, 1
                            Rectangle:
                                pos: self.pos
                                size: self.size
                Label:
                    size_hint: 0.9, 0.2   
                    pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                 
                         
#------------------------------------------------------------#
            Label:
                size_hint_y: 0.2
                text: '[b]RECENT ACTIVITY[/b]'
                markup: True
                text_size: self.size
                valign: 'center'
                halign: 'center'
            BoxLayout:
                size_hint_y: 2
                id: dynamic_activity
                orientation: 'vertical'
                spacing: dp(10)
                DynamicActivity:
                DynamicActivity:
                DynamicActivity:
                DynamicActivity:
                DynamicActivity:
                  
            Label:
                size_hint_y: 0.05
         
#------------------------------------------------------------#
#PRODUCT                  
#-----------------------------------------------------------#
<Product>:
    BoxLayout:
        size: root.size
        pos: root.pos
        orientation: 'vertical'
        spacing: dp(5)
#-------------------------------------------------------------#
# 0
#-------------------------------------------------------------#
        BoxLayout:
            size_hint: 0.95, 0.1
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
            spacing: dp(10)
            orientation: 'horizontal'
#1------------------------------------------------------------#
            ScrollView:
                size_hint_y: None
                height: dp(40)
                do_scroll: True, False
                bar_width: 0
              
                scroll_timeout: 250 
                scroll_distance: dp(20)
              
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_x: None
                    width: self.minimum_width
                    padding: [dp(20), 0]
                    spacing: dp(10)
                 
                    ToggleButton:
                        group: 'products'
                        state: 'down'
                        text: 'All'
                        size_hint_x: None
                        width: dp(60)
                        font_size: sp(14)
                        bold: True
                        background_color: 0,0,0,0
                        color: (1, 1, 1, 1) if self.state == 'down' else (1, 1, 1, 0.5)
                        canvas.before:
                            Color:
                                rgba: (0.42, 0.35, 0.88, 1) if self.state == 'down' else (0.11, 0.13, 0.18, 1)
                            RoundedRectangle:
                                size: self.size
                                pos: self.pos
                                radius: [dp(20)]
                 
                    ToggleButton:
                        group: 'products'
                        text: 'Textbooks'
                        size_hint_x: None
                        width: dp(100)
                        font_size: sp(14)
                        bold: True
                        background_color: 0,0,0,0
                        color: (1, 1, 1, 1) if self.state == 'down' else (1, 1, 1, 0.5)
                        canvas.before:
                            Color:
                                rgba: (0.42, 0.35, 0.88, 1) if self.state == 'down' else (0.11, 0.13, 0.18, 1)
                            RoundedRectangle:
                                size: self.size
                                pos: self.pos
                                radius: [dp(20)]
                 
                    ToggleButton:
                        group: 'products'
                        text: 'Notes'
                        size_hint_x: None
                        width: dp(70)
                        font_size: sp(14)
                        bold: True
                        background_color: 0,0,0,0
                        color: (1, 1, 1, 1) if self.state == 'down' else (1, 1, 1, 0.5)
                        canvas.before:
                            Color:
                                rgba: (0.42, 0.35, 0.88, 1) if self.state == 'down' else (0.11, 0.13, 0.18, 1)
                            RoundedRectangle:
                                size: self.size
                                pos: self.pos
                                radius: [dp(20)]

                    ToggleButton:
                        group: 'products'
                        text: 'Guides'
                        size_hint_x: None
                        width: dp(80)
                        font_size: sp(14)
                        bold: True
                        background_color: 0,0,0,0
                        color: (1, 1, 1, 1) if self.state == 'down' else (1, 1, 1, 0.5)
                        canvas.before:
                            Color:
                                rgba: (0.42, 0.35, 0.88, 1) if self.state == 'down' else (0.11, 0.13, 0.18, 1)
                            RoundedRectangle:
                                size: self.size
                                pos: self.pos
                                radius: [dp(20)]

                    ToggleButton:
                        group: 'products'
                        text: 'Materials'
                        size_hint_x: None
                        width: dp(90)
                        font_size: sp(14)
                        bold: True
                        background_color: 0,0,0,0
                        color: (1, 1, 1, 1) if self.state == 'down' else (1, 1, 1, 0.5)
                        canvas.before:
                            Color:
                                rgba: (0.42, 0.35, 0.88, 1) if self.state == 'down' else (0.11, 0.13, 0.18, 1)
                            RoundedRectangle:
                                size: self.size
                                pos: self.pos
                                radius: [dp(20)]
#6------------------------------------------------------------#
        ScrollView:
            id: scroll
            do_scroll: False, True
            BoxLayout:
                size_hint_y: len(self.children) * 0.2
                id: dynamic_product
                orientation: 'vertical'
                spacing: dp(10)
#Dynamic Prodoct List          
        Label:
            size_hint_y: 0.01

<EscrowBanner@BoxLayout>:
    size_hint_y: None
    height: dp(60)
    padding: dp(15)
    spacing: dp(15)
    canvas.before:
        Color:
            rgba: 0.08, 0.14, 0.16, 1 
        RoundedRectangle:
            size: self.size
            pos: self.pos
            radius: [dp(12)]
    Image:
        source: 'assets/green_shield.png'
        size_hint_x: None
        width: dp(24)
    BoxLayout:
        orientation: 'vertical'
        Label:
            text: '[b]Escrow Protected[/b]'
            markup: True
            color: 0.15, 0.76, 0.51, 1
            font_size: sp(14)
            text_size: self.size
            halign: 'left'
            valign: 'bottom'
        Label:
            text: 'Payment held securely until the buyer confirms receipt'
            color: 1, 1, 1, 0.6
            font_size: sp(11)
            text_size: self.size
            halign: 'left'
            valign: 'top'

<FormInput@BoxLayout>:
    orientation: 'vertical'
    size_hint_y: None
    height: dp(80)
    spacing: dp(8)
    title: ''
    hint: ''
    text_val: internal_input.text

    Label:
        text: root.title
        font_size: sp(14)
        bold: True
        size_hint_y: None
        height: dp(20)
        text_size: self.size
        halign: 'left'
        valign: 'middle'
    TextInput:
        id: internal_input
        hint_text: root.hint
        hint_text_color: 1, 1, 1, 0.4
        foreground_color: 1, 1, 1, 1
        background_color: 0, 0, 0, 0
        cursor_color: 0.42, 0.35, 0.88, 1
        multiline: False
        padding: [dp(15), dp(15)]
        canvas.before:
            Color:
                rgba: 0.11, 0.13, 0.18, 1
            RoundedRectangle:
                size: self.size
                pos: self.pos
                radius: [dp(8)]
            Color:
                rgba: 1, 1, 1, 0.1
            Line:
                rounded_rectangle: [self.x, self.y, self.width, self.height, dp(8)]
                width: dp(1)
<PrimaryButton@ButtonBehavior+FloatLayout>:
    text: ''
    size_hint_y: None
    height: dp(55)
    canvas.before:
        Color:
            rgba: (0.42, 0.35, 0.88, 1) if self.state == 'normal' else (0.3, 0.25, 0.7, 1)
        RoundedRectangle:
            size: self.size
            pos: self.pos
            radius: [dp(27)] 
    Label:
        text: root.text
        markup: True
        font_size: sp(16)
        pos_hint: {'center_x': 0.5, 'center_y': 0.5}
#------------------------------------------------------------#
#SELL              
#-----------------------------------------------------------#
<Sell>:
    ScrollView:
        size: root.size
        pos: root.pos
        do_scroll: False, True
        bar_width: 0
      
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height
            padding: [dp(20), dp(40), dp(20), dp(100)] 
            spacing: dp(24)

            EscrowBanner:

            # TYPE SELECTION
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: dp(75)
                spacing: dp(10)
                Label:
                    text: 'Type'
                    bold: True
                    font_size: sp(14)
                    size_hint_y: None
                    height: dp(20)
                    text_size: self.size
                    halign: 'left'
             
                BoxLayout:
                    orientation: 'horizontal'
                    spacing: dp(10)
                 
                    ToggleButton:
                        id: type_textbook
                        group: 'listing_type'
                        text: 'Textbook'
                        bold: True
                        font_size: sp(14)
                        background_color: 0, 0, 0, 0
                        color: (1, 1, 1, 1) if self.state == 'down' else (1, 1, 1, 0.5)
                        canvas.before:
                            Color:
                                rgba: (0.42, 0.35, 0.88, 0.2) if self.state == 'down' else (1, 1, 1, 0.05)
                            RoundedRectangle:
                                size: self.size
                                pos: self.pos
                                radius: [dp(12)]
                            Color:
                                rgba: (0.42, 0.35, 0.88, 1) if self.state == 'down' else (0, 0, 0, 0)
                            Line:
                                rounded_rectangle: [self.x, self.y, self.width, self.height, dp(12)]
                                width: dp(1.2)

                    ToggleButton:
                        id: type_service
                        group: 'listing_type'
                        text: 'Service'
                        bold: True
                        font_size: sp(14)
                        background_color: 0, 0, 0, 0
                        color: (1, 1, 1, 1) if self.state == 'down' else (1, 1, 1, 0.5)
                        canvas.before:
                            Color:
                                rgba: (0.42, 0.35, 0.88, 0.2) if self.state == 'down' else (1, 1, 1, 0.05)
                            RoundedRectangle:
                                size: self.size
                                pos: self.pos
                                radius: [dp(12)]
                            Color:
                                rgba: (0.42, 0.35, 0.88, 1) if self.state == 'down' else (0, 0, 0, 0)
                            Line:
                                rounded_rectangle: [self.x, self.y, self.width, self.height, dp(12)]
                                width: dp(1.2)

                    ToggleButton:
                        id: type_notes
                        group: 'listing_type'
                        text: 'Notes'
                        bold: True
                        font_size: sp(14)
                        background_color: 0, 0, 0, 0
                        color: (1, 1, 1, 1) if self.state == 'down' else (1, 1, 1, 0.5)
                        canvas.before:
                            Color:
                                rgba: (0.42, 0.35, 0.88, 0.2) if self.state == 'down' else (1, 1, 1, 0.05)
                            RoundedRectangle:
                                size: self.size
                                pos: self.pos
                                radius: [dp(12)]
                            Color:
                                rgba: (0.42, 0.35, 0.88, 1) if self.state == 'down' else (0, 0, 0, 0)
                            Line:
                                rounded_rectangle: [self.x, self.y, self.width, self.height, dp(12)]
                                width: dp(1.2)

            # INPUT FIELDS
            FormInput:
                id: title_input
                title: 'Title'
                hint: 'e.g. Organic Chemistry 8th Edition'

            FormInput:
                id: desc_input
                title: 'Description'
                hint: 'Describe condition, edition, ISBN...'
                height: dp(120) 
         
            FormInput:
                id: price_input
                title: 'Price'
                hint: '₱0.00'

            # CONDITION SELECTION
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: dp(75)
                spacing: dp(10)
                Label:
                    text: 'Condition'
                    bold: True
                    font_size: sp(14)
                    size_hint_y: None
                    height: dp(20)
                    text_size: self.size
                    halign: 'left'
             
                ScrollView:
                    do_scroll: True, False
                    bar_width: 0
                    scroll_timeout: 250 
                    scroll_distance: dp(20)
                  
                    BoxLayout:
                        id: condition_group
                        orientation: 'horizontal'
                        spacing: dp(8)
                        size_hint_x: None
                        width: self.minimum_width
                      
                        ToggleButton:
                            group: 'sells'
                            text: 'New'
                            size_hint_x: None
                            width: dp(70)
                            font_size: sp(12)
                            background_color: 0, 0, 0, 0
                            color: (1, 1, 1, 1) if self.state == 'down' else (1, 1, 1, 0.5)
                            canvas.before:
                                Color:
                                    rgba: (0.42, 0.35, 0.88, 1) if self.state == 'down' else (1, 1, 1, 0.05)
                                RoundedRectangle:
                                    size: self.size
                                    pos: self.pos
                                    radius: [dp(15)]
                     
                        ToggleButton:
                            group: 'sells'
                            text: 'Like New'
                            size_hint_x: None
                            width: dp(90)
                            font_size: sp(12)
                            background_color: 0, 0, 0, 0
                            color: (1, 1, 1, 1) if self.state == 'down' else (1, 1, 1, 0.5)
                            canvas.before:
                                Color:
                                    rgba: (0.42, 0.35, 0.88, 1) if self.state == 'down' else (1, 1, 1, 0.05)
                                RoundedRectangle:
                                    size: self.size
                                    pos: self.pos
                                    radius: [dp(15)]

                        ToggleButton:
                            group: 'sells'
                            text: 'Good'
                            size_hint_x: None
                            width: dp(70)
                            font_size: sp(12)
                            background_color: 0, 0, 0, 0
                            color: (1, 1, 1, 1) if self.state == 'down' else (1, 1, 1, 0.5)
                            canvas.before:
                                Color:
                                    rgba: (0.42, 0.35, 0.88, 1) if self.state == 'down' else (1, 1, 1, 0.05)
                                RoundedRectangle:
                                    size: self.size
                                    pos: self.pos
                                    radius: [dp(15)]
                                 
                        ToggleButton:
                            group: 'sells'
                            text: 'Fair'
                            size_hint_x: None
                            width: dp(70)
                            font_size: sp(12)
                            background_color: 0, 0, 0, 0
                            color: (1, 1, 1, 1) if self.state == 'down' else (1, 1, 1, 0.5)
                            canvas.before:
                                Color:
                                    rgba: (0.42, 0.35, 0.88, 1) if self.state == 'down' else (1, 1, 1, 0.05)
                                RoundedRectangle:
                                    size: self.size
                                    pos: self.pos
                                    radius: [dp(15)]

                        ToggleButton:
                            group: 'sells'
                            text: 'Digital'
                            size_hint_x: None
                            width: dp(80)
                            font_size: sp(12)
                            background_color: 0, 0, 0, 0
                            color: (1, 1, 1, 1) if self.state == 'down' else (1, 1, 1, 0.5)
                            canvas.before:
                                Color:
                                    rgba: (0.42, 0.35, 0.88, 1) if self.state == 'down' else (1, 1, 1, 0.05)
                                RoundedRectangle:
                                    size: self.size
                                    pos: self.pos
                                    radius: [dp(15)]

            # PUBLISH BUTTON
            PrimaryButton:
                id: publish_btn
                text: '[b]Publish[/b]'
                on_release: root.add_product()
#------------------------------------------------------------#
#SERVICE                  
#-----------------------------------------------------------#
<Service>:
    BoxLayout:
        size: root.size
        pos: root.pos
        orientation: 'vertical'
        spacing: dp(5)
#-------------------------------------------------------------#
# 0
#-------------------------------------------------------------#
        BoxLayout:
            size_hint: 0.95, 0.1
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
            spacing: dp(10)
            orientation: 'horizontal'
#1------------------------------------------------------------#
            ScrollView:
                size_hint_y: None
                height: dp(40)
                do_scroll: True, False
                bar_width: 0
              
                scroll_timeout: 250 
                scroll_distance: dp(20)
              
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_x: None
                    width: self.minimum_width
                    padding: [dp(20), 0]
                    spacing: dp(10)
                 
                    ToggleButton:
                        group: 'services'
                        state: 'down'
                        text: 'All'
                        size_hint_x: None
                        width: dp(60)
                        font_size: sp(14)
                        bold: True
                        background_color: 0,0,0,0
                        color: (1, 1, 1, 1) if self.state == 'down' else (1, 1, 1, 0.5)
                        canvas.before:
                            Color:
                                rgba: (0.42, 0.35, 0.88, 1) if self.state == 'down' else (0.11, 0.13, 0.18, 1)
                            RoundedRectangle:
                                size: self.size
                                pos: self.pos
                                radius: [dp(20)]
                 
                    ToggleButton:
                        group: 'services'
                        text: 'Tutoring'
                        size_hint_x: None
                        width: dp(90)
                        font_size: sp(14)
                        bold: True
                        background_color: 0,0,0,0
                        color: (1, 1, 1, 1) if self.state == 'down' else (1, 1, 1, 0.5)
                        canvas.before:
                            Color:
                                rgba: (0.42, 0.35, 0.88, 1) if self.state == 'down' else (0.11, 0.13, 0.18, 1)
                            RoundedRectangle:
                                size: self.size
                                pos: self.pos
                                radius: [dp(20)]
                 
                    ToggleButton:
                        group: 'services'
                        text: 'Writing'
                        size_hint_x: None
                        width: dp(80)
                        font_size: sp(14)
                        bold: True
                        background_color: 0,0,0,0
                        color: (1, 1, 1, 1) if self.state == 'down' else (1, 1, 1, 0.5)
                        canvas.before:
                            Color:
                                rgba: (0.42, 0.35, 0.88, 1) if self.state == 'down' else (0.11, 0.13, 0.18, 1)
                            RoundedRectangle:
                                size: self.size
                                pos: self.pos
                                radius: [dp(20)]

                    ToggleButton:
                        group: 'services'
                        text: 'Career'
                        size_hint_x: None
                        width: dp(80)
                        font_size: sp(14)
                        bold: True
                        background_color: 0,0,0,0
                        color: (1, 1, 1, 1) if self.state == 'down' else (1, 1, 1, 0.5)
                        canvas.before:
                            Color:
                                rgba: (0.42, 0.35, 0.88, 1) if self.state == 'down' else (0.11, 0.13, 0.18, 1)
                            RoundedRectangle:
                                size: self.size
                                pos: self.pos
                                radius: [dp(20)]

                    ToggleButton:
                        group: 'services'
                        text: 'Test Prep'
                        size_hint_x: None
                        width: dp(100)
                        font_size: sp(14)
                        bold: True
                        background_color: 0,0,0,0
                        color: (1, 1, 1, 1) if self.state == 'down' else (1, 1, 1, 0.5)
                        canvas.before:
                            Color:
                                rgba: (0.42, 0.35, 0.88, 1) if self.state == 'down' else (0.11, 0.13, 0.18, 1)
                            RoundedRectangle:
                                size: self.size
                                pos: self.pos
                                radius: [dp(20)]
#6------------------------------------------------------------#
        ScrollView:
            id: scroll
            do_scroll: False, True
            BoxLayout:
                size_hint_y: len(self.children) * 0.2
                id: dynamic_service
                orientation: 'vertical'
                spacing: dp(10)
#Dynamic Service List          
        Label:
            size_hint_y: 0.01
          
#-----------------------------------------------------------#
# Custom Dynamic Class for NavBackButton
#-----------------------------------------------------------#
<NavBackButton@ButtonBehavior+BoxLayout>:
    size_hint: None, None
    size: dp(40), dp(40)
    canvas.before:
        Color:
            rgba: 0.15, 0.16, 0.22, 1
        RoundedRectangle:
            size: self.size
            pos: self.pos
            radius: [dp(10)]
    Label:
        text: '<'
        font_size: sp(18)
        bold: True
        pos_hint: {'center_x': 0.5, 'center_y': 0.5}

#-----------------------------------------------------------#
# Custom Dynamic Class for Menu List Items
#-----------------------------------------------------------#
<CardBase@BoxLayout>:
    canvas.before:
        Color:
            rgba: 0.11, 0.12, 0.16, 1  # Dark Card Background
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(12)]
<ListTile>:
    size_hint_y: None
    height: dp(70)
    padding: dp(15)
    spacing: dp(15)
    canvas.before:
        Color:
            rgba: 0.11, 0.12, 0.16, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(12)]
   
    # Left Icon
    FloatLayout:
        size_hint: None, None
        size: dp(40), dp(40)
        pos_hint: {'center_y': 0.5}
        canvas.before:
            Color:
                rgba: 0.15, 0.16, 0.22, 1
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(10)]
        # Replaced the placeholder Label with the actual Image
        Image:
            source: root.icon_source
            size_hint: 0.5, 0.5
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}

    # Text Content
    BoxLayout:
        orientation: 'vertical'
        spacing: dp(2)
        pos_hint: {'center_y': 0.5}
        Label:
            text: root.title
            font_size: sp(16)
            bold: True
            color: 1, 1, 1, 1
            text_size: self.size
            halign: 'left'
            valign: 'bottom'
        Label:
            text: root.subtitle
            font_size: sp(12)
            color: 0.6, 0.6, 0.6, 1
            text_size: self.size
            halign: 'left'
            valign: 'top'
   
    # Right Arrow (Optional)
    Label:
        text: '>' if root.show_arrow else ''
        size_hint_x: None
        width: dp(20)
        color: 0.5, 0.5, 0.5, 1
        font_size: sp(18)

<WalletAction@ButtonBehavior+BoxLayout>:
    orientation: 'horizontal'
    padding: [dp(20), dp(10)]
    spacing: dp(10)
    icon: ''
    text: ''
    canvas.before:
        Color:
            rgba: 1, 1, 1, 0.2
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(10)]
    Image:
        source: root.icon
        size_hint_x: None
        width: dp(24)
    Label:
        text: root.text
        bold: True
        font_size: sp(14)
        text_size: self.size
        halign: 'left'
        valign: 'middle'

<ChatBubble>:
    size_hint_y: None
    height: self.minimum_height
    padding: [dp(10), dp(5)]
    # Anchor left or right based on sender
    AnchorLayout:
        anchor_x: 'right' if root.is_sender else 'left'
        size_hint_y: None
        height: bubble_container.height
       
        BoxLayout:
            id: bubble_container
            orientation: 'vertical'
            size_hint: None, None
            width: min(dp(250), root.width * 0.75)
            height: self.minimum_height
            padding: dp(15)
            spacing: dp(5)
            canvas.before:
                Color:
                    rgba: (0.43, 0.33, 0.85, 1) if root.is_sender else (0.15, 0.16, 0.22, 1)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(15), dp(15), dp(0) if root.is_sender else dp(15), dp(15) if root.is_sender else dp(0)]
            Label:
                text: root.text
                size_hint_y: None
                height: self.texture_size[1]
                text_size: self.width, None
                color: 1, 1, 1, 1
            Label:
                text: root.time
                font_size: sp(10)
                size_hint_y: None
                height: dp(12)
                text_size: self.width, None
                halign: 'right' if root.is_sender else 'left'
                color: 0.8, 0.8, 0.8, 0.7
<MenuItem@ButtonBehavior+BoxLayout>:
    size_hint_y: None
    height: dp(55)
    spacing: dp(15)
    padding: [dp(10), dp(5), dp(10), dp(5)]
   
    # Custom properties to easily pass data
    icon_source: ''
    text: ''
    text_color: 1, 1, 1, 1
    icon_bg_color: 0.12, 0.13, 0.20, 1

    # Icon Container with Rounded Background
    FloatLayout:
        size_hint_x: None
        width: dp(45)
        canvas.before:
            Color:
                rgba: root.icon_bg_color
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(12)]
        Image:
            source: root.icon_source
            size_hint: 0.5, 0.5
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}

    # Left-Aligned Text Label
    Label:
        text: root.text
        color: root.text_color
        font_size: sp(16)
        bold: True
        text_size: self.size
        halign: 'left'
        valign: 'middle'

<Divider@Widget>:
    size_hint_y: None
    height: dp(1)
    canvas.before:
        Color:
            rgba: 0.15, 0.16, 0.22, 1 # Faint divider line
        Rectangle:
            pos: self.pos
            size: self.size

<SettingsTile@BoxLayout>:
    size_hint_y: None
    height: dp(70)
    padding: dp(15)
    spacing: dp(15)
   
    # We define custom properties so we can reuse this tile
    icon_source: ''
    title: ''
    subtitle: ''
   
    # Left Icon Background
    FloatLayout:
        size_hint: None, None
        size: dp(40), dp(40)
        pos_hint: {'center_y': 0.5}
        canvas.before:
            Color:
                rgba: 0.15, 0.16, 0.22, 1
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(10)]
        Image:
            source: root.icon_source
            size_hint: 0.5, 0.5
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}

    # Text Content
    BoxLayout:
        orientation: 'vertical'
        spacing: dp(2)
        pos_hint: {'center_y': 0.5}
        Label:
            text: root.title
            font_size: sp(16)
            bold: True
            color: 1, 1, 1, 1
            text_size: self.size
            halign: 'left'
            valign: 'bottom'
        Label:
            text: root.subtitle
            font_size: sp(12)
            color: 0.6, 0.6, 0.6, 1
            text_size: self.size
            halign: 'left'
            valign: 'top'
   
    # Right Arrow
    Label:
        text: '>'
        size_hint_x: None
        width: dp(20)
        color: 0.5, 0.5, 0.5, 1
        font_size: sp(18)


#-----------------------------------------------------------#
# MAIN STATUS SCREEN
#-----------------------------------------------------------#
<Status>:
    # 1. Main Background Color
    canvas.before:
        Color:
            rgba: 0,0,0,0
        Rectangle:
            pos: self.pos
            size: self.size
    ScreenManager:
        size: root.size
        pos: root.pos
        id: screenmanager
        Screen:
            name: 'menu'
            BoxLayout:
                orientation: 'vertical'
                size: root.size
                pos: root.pos
              
                ScrollView:
                    do_scroll: False, True
                    bar_width: 0

                    # 2. Inner Scrolling Layout (Must have size_hint_y: None)
                    BoxLayout:
                        orientation: 'vertical'
                        size_hint_y: None
                        height: self.minimum_height
                        padding: dp(20)
                        spacing: dp(30)

                        # --- TOP SECTION: PROFILE INFO ---
                        BoxLayout:
                            orientation: 'vertical'
                            size_hint_y: None
                            height: self.minimum_height
                            spacing: dp(10)

                            # Avatar Container
                            FloatLayout:
                                size_hint: None, None
                                size: dp(100), dp(100)
                                pos_hint: {'center_x': 0.5}

                                # Purple initials circle
                                canvas.before:
                                    Color:
                                        rgba: 0.12, 0.13, 0.20, 1 # Slightly lighter dark circle
                                    Ellipse:
                                        pos: self.pos
                                        size: self.size
                                Label:
                                    text: f'[b]{root.initial}[/b]' # Example: 'JD'
                                    markup: True
                                    font_size: sp(36)
                                    color: 0.4, 0.31, 0.85, 1 # Purple accent
                                    pos_hint: {'center_x': 0.5, 'center_y': 0.5}

                                # Overlapping Camera Badge
                                FloatLayout:
                                    size_hint: None, None
                                    size: dp(32), dp(32)
                                    pos_hint: {'right': 1.0, 'y': 0}
                                    canvas.before:
                                        Color:
                                            rgba: 0.4, 0.31, 0.85, 1
                                        Ellipse:
                                            pos: self.pos
                                            size: self.size
                                    Image:
                                        source: 'assets/camera.png' # Ensure this asset exists
                                        size_hint: 0.5, 0.5
                                        pos_hint: {'center_x': 0.5, 'center_y': 0.5}

                            # Names and Handles
                            Label:
                                text: f'[b]{root.full_name}[/b]' # Example: 'Jane Doe'
                                markup: True
                                font_size: sp(22)
                                size_hint_y: None
                                height: dp(30)
                                color: 1, 1, 1, 1

                            Label:
                                text: f'{root.email}' # Example: '@janedoe'
                                font_size: sp(14)
                                size_hint_y: None
                                height: dp(20)
                                color: 0.6, 0.6, 0.6, 1

                            # Badges Row (Verified & Rating)
                            BoxLayout:
                                orientation: 'horizontal'
                                size_hint: None, None
                                height: dp(35)
                                width: self.minimum_width
                                pos_hint: {'center_x': 0.5}
                                spacing: dp(10)

                                # Verified Badge
                                BoxLayout:
                                    size_hint_x: None
                                    width: dp(95)
                                    padding: [dp(10), dp(5), dp(10), dp(5)]
                                    spacing: dp(5)
                                    canvas.before:
                                        Color:
                                            rgba: 0.10, 0.15, 0.15, 1 # Subtle dark green BG
                                        RoundedRectangle:
                                            pos: self.pos
                                            size: self.size
                                            radius: [dp(15)]
                                        Color:
                                            rgba: 0.2, 0.8, 0.4, 0.5 # Green Border Line
                                        Line:
                                            rounded_rectangle: [self.x, self.y, self.width, self.height, dp(15)]
                                            width: dp(1)
                                    Image:
                                        source: 'assets/green_shield.png'
                                        size_hint_x: None
                                        width: dp(15)
                                    Label:
                                        text: 'Verified'
                                        color: 0.2, 0.8, 0.4, 1
                                        font_size: sp(12)
                                        bold: True

                                # Rating Badge
                                BoxLayout:
                                    size_hint_x: None
                                    width: dp(75)
                                    padding: [dp(10), dp(5), dp(10), dp(5)]
                                    spacing: dp(5)
                                    canvas.before:
                                        Color:
                                            rgba: 0.15, 0.12, 0.20, 1 # Subtle dark purple BG
                                        RoundedRectangle:
                                            pos: self.pos
                                            size: self.size
                                            radius: [dp(15)]
                                        Color:
                                            rgba: 0.4, 0.31, 0.85, 0.5 # Purple Border Line
                                        Line:
                                            rounded_rectangle: [self.x, self.y, self.width, self.height, dp(15)]
                                            width: dp(1)
                                    Image:
                                        source: 'assets/star.png'
                                        size_hint_x: None
                                        width: dp(15)
                                    Label:
                                        text: '4.9'
                                        color: 0.4, 0.31, 0.85, 1
                                        font_size: sp(12)
                                        bold: True

                        # --- BOTTOM SECTION: MENU LIST ---
                        BoxLayout:
                            orientation: 'vertical'
                            size_hint_y: None
                            height: self.minimum_height
                            spacing: dp(5)

                            # Instantiate custom MenuItems
                            MenuItem:
                                icon_source: 'assets/profile.png'
                                text: 'My Profile'
                                on_release: 
                                    screenmanager.current = 'profile'
                                    root.parent.parent.parent.parent.ids.label1.text = '[b]MY PROFILE[/b]'
                                    root.parent.parent.parent.parent.ids.label2.text = 'view your details'
                                    root.parent.parent.parent.parent.ids.back_btn.opacity = 1
                                    root.parent.parent.parent.parent.ids.back_btn.disabled = False
                              
                            MenuItem:
                                icon_source: 'assets/chat.png'
                                text: 'Inbox'
                                on_release: 
                                    screenmanager.current = 'inbox'
                                    screenmanager.get_screen('inbox').children[0].load_inbox()
                                    root.parent.parent.parent.parent.ids.label1.text = '[b]INBOX[/b]'
                                    root.parent.parent.parent.parent.ids.label2.text = 'Your active conversations'
                                    root.parent.parent.parent.parent.ids.back_btn.opacity = 1
                                    root.parent.parent.parent.parent.ids.back_btn.disabled = False
                              
                            MenuItem:
                                icon_source: 'assets/wallet.png'
                                text: 'Wallet'
                                on_release: 
                                    screenmanager.current = 'wallet'
                                    root.parent.parent.parent.parent.ids.label1.text = '[b]WALLET[/b]'
                                    screenmanager.get_screen('wallet').children[0].load_balance()
                                    root.parent.parent.parent.parent.ids.label2.text = 'manage your funds'
                                    root.parent.parent.parent.parent.ids.back_btn.opacity = 1
                                    root.parent.parent.parent.parent.ids.back_btn.disabled = False
                              
                            MenuItem:
                                icon_source: 'assets/settings.png'
                                text: 'Settings'
                                on_release: 
                                    screenmanager.current = 'settings'
                                    root.parent.parent.parent.parent.ids.label1.text = '[b]SETTINGS[/b]'
                                    root.parent.parent.parent.parent.ids.label2.text = 'manage your preferences'
                                    root.parent.parent.parent.parent.ids.back_btn.opacity = 1
                                    root.parent.parent.parent.parent.ids.back_btn.disabled = False
                              
                            MenuItem:
                                icon_source: 'assets/logout.png'
                                text: 'Sign Out'
                                text_color: 0.8, 0.2, 0.2, 1       # Red text
                                icon_bg_color: 0.15, 0.05, 0.05, 1 # Faint red background
                                on_release: 
                                    screenmanager.current = 'logout'
                                    root.parent.parent.parent.parent.ids.label1.text = '[b]SIGN OUT[/b]'
                                    root.parent.parent.parent.parent.ids.label2.text = 'disconnect securely'
                                    root.parent.parent.parent.parent.ids.back_btn.opacity = 1
                                    root.parent.parent.parent.parent.ids.back_btn.disabled = False
        Screen:
            name: 'profile'
            Profile:
                size: root.size
                pos: root.pos
        Screen:
            name: 'inbox'       
            InboxScreen:
        Screen:
            name: 'chatbox'
            ChatBox:
                size: root.size
                pos: root.pos
        Screen:
            name: 'settings'
            UserSettings:
        Screen:
            name: 'wallet'
            Wallet:
                size: root.size
                pos: root.pos
        Screen:
            name: 'logout'
            LogOut:
                size: root.size
                pos: root.pos

<EditProfileButton@ButtonBehavior+FloatLayout>:
    size_hint_y: None
    height: dp(50)
    canvas.before:
        Color:
            rgba: 0.43, 0.33, 0.85, 1
        Line:
            rounded_rectangle: [self.x, self.y, self.width, self.height, dp(12)]
            width: dp(1.2)
            
    BoxLayout:
        spacing: dp(8)
        size_hint: None, 1
        width: self.minimum_width
        pos_hint: {'center_x': 0.5}
        Image:
            source: 'assets/edit.png'
            size_hint_x: None
            width: dp(18)
        Label:
            text: '[b]Edit Profile[/b]'
            markup: True
            color: 1, 1, 1, 1
            size_hint_x: None
            width: self.texture_size[0]

<IconButton@ButtonBehavior+AnchorLayout>:
    icon_source: ''
    icon_size_hint: 0.5, 0.5
    canvas.before:
        Color:
            rgba: (1, 1, 1, 0) # Default transparent
        Rectangle:
            pos: self.pos
            size: self.size
    Image:
        source: root.icon_source
        size_hint: root.icon_size_hint

# FIX: Specialized Send Button with background styling
<SendButton@ButtonBehavior+AnchorLayout>:
    icon_source: 'assets/send.png'
    canvas.before:
        Color:
            rgba: 0.43, 0.33, 0.85, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(25)]
    Image:
        source: root.icon_source
        size_hint: 0.45, 0.45

<InboxTile>:
    size_hint_y: None
    height: dp(85)
    padding: dp(15)
    spacing: dp(15)
    on_release: self.open_chat()
    canvas.before:
        Color:
            rgba: (0.15, 0.16, 0.22, 1) if self.state == 'normal' else (0.20, 0.21, 0.28, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(15)]

    # Avatar Box
    FloatLayout:
        size_hint_x: None
        width: dp(50)
        canvas.before:
            Color:
                rgba: 0.43, 0.33, 0.85, 1
            Ellipse:
                pos: [self.center_x - dp(25), self.center_y - dp(25)]
                size: dp(50), dp(50)
        Label:
            text: f'[b]{root.partner_name[0:2].upper() if root.partner_name else ""}[/b]'
            markup: True
            font_size: sp(16)
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}

    # Text Content
    BoxLayout:
        orientation: 'vertical'
        spacing: dp(2)
        Label:
            text: f'[b]{root.partner_name}[/b]'
            markup: True
            font_size: sp(16)
            text_size: self.size
            halign: 'left'
            valign: 'bottom'
        Label:
            text: root.last_message
            color: 0.6, 0.6, 0.6, 1
            font_size: sp(13)
            text_size: self.size
            halign: 'left'
            valign: 'top'
            shorten: True
            shorten_from: 'right'

    # Timestamp
    Label:
        size_hint_x: None
        width: dp(65)
        text: root.time
        color: 0.5, 0.5, 0.5, 1
        font_size: sp(11)
        text_size: self.size
        halign: 'right'
        valign: 'top'

<InboxScreen>:
    orientation: 'vertical'
    padding: [dp(20), dp(5), dp(20), dp(20)]
    ScrollView:
        do_scroll: False, True
        bar_width: 0
        BoxLayout:
            id: inbox_list
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height
            spacing: dp(10)        

# ------------------- 1. PROFILE SCREEN ------------------- #
<Profile>:
    size: root.size
    pos: root.pos
    orientation: 'vertical'
    padding: [dp(20), dp(5), dp(20), dp(20)]
    spacing: dp(15)

    ScrollView:
        do_scroll: False, True
        bar_width: 0
        
        # Priority Mobile Constraint: Limit touch dispatching to prevent lock-ups
        scroll_timeout: 250
        scroll_distance: dp(20)

        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height
            spacing: dp(20)

            # Avatar Header
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: dp(150)
                spacing: dp(5)
                FloatLayout:
                    size_hint: None, None
                    size: dp(90), dp(90)
                    pos_hint: {'center_x': 0.5}
                    canvas.before:
                        Color:
                            rgba: 0.12, 0.13, 0.20, 1
                        Ellipse:
                            pos: self.pos
                            size: self.size
                    Label:
                        text: '[b]JD[/b]'
                        markup: True
                        font_size: sp(32)
                        color: 0.43, 0.33, 0.85, 1
                        pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                Label:
                    text: '[b]Jane Doe[/b]'
                    markup: True
                    font_size: sp(20)
                    size_hint_y: None
                    height: dp(25)
                Label:
                    text: '@janedoe'
                    font_size: sp(14)
                    color: 0.6, 0.6, 0.6, 1
                    size_hint_y: None
                    height: dp(20)
         
            # Info Cards
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(10)
                
                # Assuming <ListTile> is successfully defined elsewhere in your .kv
                ListTile:
                    icon_source: 'assets/email.png'
                    title: 'Email'
                    subtitle: 'jane.doe@university.edu'
                    show_arrow: False
                ListTile:
                    icon_source: 'assets/phone.png'
                    title: 'Phone'
                    subtitle: '+1 (555) 123-4567'
                    show_arrow: False
                ListTile:
                    icon_source: 'assets/school.png'
                    title: 'University'
                    subtitle: 'State University'
                    show_arrow: False
                ListTile:
                    icon_source: 'assets/location.png'
                    title: 'Location'
                    subtitle: 'Campus Dorm B, Room 204'
                    show_arrow: False
         
            # FIX: Call the valid dynamic class instead of the abstract ButtonBehavior
            EditProfileButton:
                on_release: print("Edit profile triggered")

# ------------------- 2. CHATBOX SCREEN ------------------- #
<ChatBox>:
    size: root.size
    pos: root.pos
    orientation: 'vertical'
   
    # Top Bar
    BoxLayout:
        size_hint_y: None
        height: dp(60)
        padding: dp(10)
        spacing: dp(10)
        canvas.before:
            Color:
                rgba: 0.11, 0.12, 0.16, 1
            Rectangle:
                pos: self.pos
                size: self.size
               
        FloatLayout:
            size_hint: None, None
            size: dp(40), dp(40)
            canvas.before:
                Color:
                    rgba: 0.15, 0.12, 0.25, 1
                Ellipse:
                    pos: self.pos
                    size: self.size
        BoxLayout:
            orientation: 'vertical'
            Label:
                id: chat_header_name
                text: '[b]User[/b]'
                markup: True
                text_size: self.size
                halign: 'left'
                valign: 'bottom'
            Label:
                text: 'Online'
                color: 0.2, 0.8, 0.4, 1
                font_size: sp(12)
                text_size: self.size
                halign: 'left'
                valign: 'top'
   
    # Chat Area
    ScrollView:
        do_scroll: False, True
        scroll_timeout: 250 # Mobile Responsiveness fix
        scroll_distance: dp(20)
        BoxLayout:
            id: chat_history
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height
            padding: dp(15)
            spacing: dp(15)
   
    # Input Bar
    BoxLayout:
        size_hint_y: None
        height: dp(70)
        padding: dp(15)
        spacing: dp(10)
        canvas.before:
            Color:
                rgba: 0.11, 0.12, 0.16, 1
            Rectangle:
                pos: self.pos
                size: self.size
       
        # FIX: Replaced raw ButtonBehavior with valid IconButton
        IconButton:
            size_hint_x: None
            width: dp(30)
            icon_source: 'assets/attach.png'
            icon_size_hint: 0.8, 0.8
            on_release: print("Attach file triggered")
       
        TextInput:
            id: chat_input
            hint_text: 'Type a message...'
            background_color: 0,0,0,0
            foreground_color: 1,1,1,1
            hint_text_color: 0.5, 0.5, 0.5, 1
            multiline: False
            padding: [dp(15), dp(10)]
            canvas.before:
                Color:
                    rgba: 0.15, 0.16, 0.22, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(20)]
       
        # FIX: Replaced raw ButtonBehavior with valid SendButton
        SendButton:
            size_hint_x: None
            width: dp(50)
            on_release: root.send_new_message()

# ------------------- 3. WALLET SCREEN ------------------- #
<Wallet>:
    size: root.size
    pos: root.pos
    orientation: 'vertical'
    padding: [dp(20), dp(5), dp(20), dp(20)]
    spacing: dp(15)

    ScrollView:
        do_scroll: False, True
        bar_width: 0
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height
            spacing: dp(25)

            # Big Purple Card
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: dp(230)
                padding: dp(20)
                canvas.before:
                    Color:
                        rgba: 0.43, 0.33, 0.85, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(20)]
                Label:
                    text: 'Available Balance'
                    font_size: sp(14)
                    size_hint_y: None
                    height: dp(20)
                    text_size: self.size
                    halign: 'left'
                Label:
                    id: balance_label
                    text: '[b]$0.00[/b]'
                    markup: True
                    font_size: sp(36)
                    size_hint_y: None
                    height: dp(50)
                    text_size: self.size
                    halign: 'left'
                TextInput:
                    id: amount_input
                    hint_text: 'Enter amount (e.g. 500)'
                    multiline: False
                    input_filter: 'float'
                    size_hint_y: None
                    height: dp(40)
                    background_color: 1, 1, 1, 0.1
                    foreground_color: 1, 1, 1, 1
                    padding: [dp(10), dp(10)]
                    canvas.before:
                        Color:
                            rgba: 1, 1, 1, 0.2
                        Line:
                            rounded_rectangle: [self.x, self.y, self.width, self.height, dp(5)]
                            width: dp(1)
                # Action Buttons
                BoxLayout:
                    spacing: dp(15)
                    padding: [0, dp(15), 0, 0]
                    WalletAction:
                        icon: 'assets/green_up.png'
                        text: 'Deposit'
                        on_release: root.process_transaction('deposit')
                    WalletAction:
                        icon: 'assets/red_down.png'
                        text: 'Withdraw'
                        on_release: root.process_transaction('withdraw')

            # Payment Methods
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(10)
                Label:
                    text: '[b]Recent Transactions[/b]'
                    markup: True
                    font_size: sp(16)
                    color: 1, 1, 1, 1
                    size_hint_y: None
                    height: dp(40)
                    text_size: self.size
                    halign: 'left'
                    valign: 'middle'

                ScrollView:
                    do_scroll: False, True
                    bar_width: 0
                    BoxLayout:
                        id: history_list  # <-- The Python logic looks for this!
                        orientation: 'vertical'
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: dp(10)

# ------------------- 4. SETTINGS SCREEN ------------------- #
<UserSettings>:
    orientation: 'vertical'
    padding: [dp(20), dp(5), dp(20), dp(20)]
    spacing: dp(10)

    # Master Background for the Settings Screen
    canvas.before:
        Color:
            rgba: 0.07, 0.08, 0.11, 1
        Rectangle:
            pos: self.pos
            size: self.size

    # Scrollable Settings List
    ScrollView:
        do_scroll: False, True
        bar_width: 0
      
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height
            spacing: dp(25)
            padding: [0, dp(15), 0, dp(20)]

            # --- ACCOUNT SECTION ---
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(10)
                Label:
                    text: 'ACCOUNT'
                    font_size: sp(12)
                    color: 0.6, 0.6, 0.6, 1
                    text_size: self.size
                    halign: 'left'
                    size_hint_y: None
                    height: dp(20)
             
                # Card Container
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: self.minimum_height
                    canvas.before:
                        Color:
                            rgba: 0.11, 0.12, 0.16, 1
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(12)]
                 
                    SettingsTile:
                        icon_source: 'assets/lock.png'
                        title: 'Privacy & Security'
                        subtitle: 'Password, 2FA, sessions'
                    Divider:
                    SettingsTile:
                        icon_source: 'assets/bank.png'
                        title: 'Payment Methods'
                        subtitle: 'Cards, wallets, escrow'
                    Divider:
                    SettingsTile:
                        icon_source: 'assets/university.png'
                        title: 'University'
                        subtitle: 'State University'

            # --- PREFERENCES SECTION ---
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(10)
                Label:
                    text: 'PREFERENCES'
                    font_size: sp(12)
                    color: 0.6, 0.6, 0.6, 1
                    text_size: self.size
                    halign: 'left'
                    size_hint_y: None
                    height: dp(20)
             
                # Card Container
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: self.minimum_height
                    canvas.before:
                        Color:
                            rgba: 0.11, 0.12, 0.16, 1
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(12)]
                 
                    SettingsTile:
                        icon_source: 'assets/notifaction.png'
                        title: 'Notifications'
                        subtitle: 'Push, email, SMS'
                    Divider:
                    SettingsTile:
                        icon_source: 'assets/visibility.png'
                        title: 'Appearance'
                        subtitle: 'Theme & display'
                    Divider:
                    SettingsTile:
                        icon_source: 'assets/language.png'
                        title: 'Language'
                        subtitle: 'English (US)'

            # --- SUPPORT SECTION ---
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(10)
                Label:
                    text: 'SUPPORT'
                    font_size: sp(12)
                    color: 0.6, 0.6, 0.6, 1
                    text_size: self.size
                    halign: 'left'
                    size_hint_y: None
                    height: dp(20)
             
                # Card Container
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: self.minimum_height
                    canvas.before:
                        Color:
                            rgba: 0.11, 0.12, 0.16, 1
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(12)]
                 
                    SettingsTile:
                        icon_source: 'assets/help.png' 
                        title: 'Help Center'
                        subtitle: 'FAQs & guides'

# ------------------- 5. LOGOUT SCREEN ------------------- #
<LogOut>:
    size: root.size
    pos: root.pos
    canvas.before:
        Color:
            rgba: 0.07, 0.08, 0.11, 0.95 # Slight opacity for overlay feel
        Rectangle:
            pos: self.pos
            size: self.size
   
    BoxLayout:
        orientation: 'vertical'
        size_hint: 0.85, None
        height: self.minimum_height
        pos_hint: {'center_x': 0.5, 'center_y': 0.6}
        spacing: dp(20)

        # Red Icon
        FloatLayout:
            size_hint_y: None
            height: dp(80)
            canvas.before:
                Color:
                    rgba: 0.15, 0.05, 0.05, 1
                Ellipse:
                    pos: [self.center_x - dp(40), self.y]
                    size: dp(80), dp(80)
            Image:
                source: 'assets/logout.png' 
                size_hint: 0.5, 0.5
                pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                color: 0.88, 0.25, 0.25, 1

        # Text
        Label:
            text: '[b]Sign Out?[/b]'
            markup: True
            font_size: sp(24)
            size_hint_y: None
            height: dp(30)
        Label:
            text: 'Are you sure you want to sign out of ScholarBridge?'
            color: 0.6, 0.6, 0.6, 1
            text_size: self.width, None
            halign: 'center'
            size_hint_y: None
            height: self.texture_size[1]
        Label:
            text: 'Active escrow transactions are safe'
            color: 0.16, 0.67, 0.38, 1
            font_size: sp(12)
            size_hint_y: None
            height: dp(20)

        # Buttons
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: dp(120)
            spacing: dp(15)
            padding: [0, dp(10), 0, 0]

            Button:
                text: '[b]Sign Out[/b]'
                markup: True
                background_color: 0,0,0,0
                canvas.before:
                    Color:
                        rgba: 0.88, 0.25, 0.25, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(12)]
                on_release:
                    main_interface.Data.user = {} # Clear active user cache
                    if os.path.exists('local_state.json'): os.remove('local_state.json')
                    app.root.logged = False
                    app.root.current = "start"
         
            Button:
                text: '[b]Cancel[/b]'
                markup: True
                background_color: 0,0,0,0
                canvas.before:
                    Color:
                        rgba: 0.11, 0.12, 0.16, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(12)]
                    Color:
                        rgba: 0.3, 0.3, 0.3, 1
                    Line:
                        rounded_rectangle: [self.x, self.y, self.width, self.height, dp(12)]
                        width: dp(1)
                # Wired Up LogOut Cancel button to hide the global back button
                on_release:
                    root.parent.manager.current = 'menu'
                    root.parent.parent.parent.parent.parent.parent.parent.ids.label1.text = '[b]MENU[/b]'
                    root.parent.parent.parent.parent.parent.parent.parent.ids.label2.text = 'manage your account'
                    root.parent.parent.parent.parent.parent.parent.parent.ids.back_btn.opacity = 0
                    root.parent.parent.parent.parent.parent.parent.parent.ids.back_btn.disabled = True
