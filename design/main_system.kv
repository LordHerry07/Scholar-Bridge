#:import main_interface core.main_interface

# ==========================================
# DOMAIN: CORE NAVIGATION & LAYOUT
# ==========================================

# -------------------------------
# SCREEN: Root Manager
# -------------------------------
<Interface>:
    id: interface
    StartInterface:
        name: "start"
        id: start
    MainInterface:
        name: "main"
        id: main

# -------------------------------
# SCREEN: Main Wrapper & Footer
# -------------------------------
<MainInterface>:
    canvas.before:
        Color:
            rgba: 0.08, 0.09, 0.14, 1
        Rectangle:
            size: root.size
            pos: root.pos
            
    BoxLayout:
        orientation: 'vertical'
        
        # 1. THE GLOBAL HEADER
        BoxLayout:
            size_hint_y: 0.1
            orientation: 'vertical'
            spacing: dp(10)
            BoxLayout:
                size_hint: 0.9, 0.1
                pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                orientation: 'horizontal'
                BoxLayout:
                    orientation: 'vertical'
                    Label:
                        id: label1
                        text: '[b]DASHBOARD[/b]'
                        text_size: self.size
                        font_size: dp(19)
                        markup: True
                        valign: 'bottom'
                        halign: 'left'
                    Label:
                        id: label2
                        text: 'your activity overview'
                        color: 1,1,1,0.5
                        text_size: self.size
                        valign: 'top'
                        halign: 'left'
                NavBackButton:
                    id: back_btn
                    opacity: 0
                    disabled: True 
                    pos_hint: {'center_y': 0.5}
                    on_release:
                        screenmanager.get_screen('info').children[0].ids.screenmanager.current = 'menu'
                        label1.text = '[b]MENU[/b]'
                        label2.text = 'manage your account'
                        self.opacity = 0
                        self.disabled = True
                        root.toggle_footer(True)
                        footer_nav.opacity = 1
                        footer_nav.size_hint_y = 0.1
                        footer_nav.disabled = False
                        info.state = 'down'
                        app.root.get_screen('main').toggle_footer(True)
                        
        # 2. THE MAIN SCREEN MANAGER
        ScreenManager:
            id: screenmanager
            size_hint: 0.9, 0.95
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
            Screen:
                name: 'dashboard'
                Dashboard:
            Screen:
                name: 'product'
                Product:
            Screen:
                name: 'sell'
                Sell:
            Screen:
                name: 'service'
                Service:
            Screen:
                name: 'info'
                Status:

        # 3. THE GLOBAL FOOTER NAVIGATION
        BoxLayout:
            id: footer_nav 
            size_hint: 0.98, 0.1
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
            orientation: 'horizontal'
            canvas.before:
                Color:
                    rgba: 1,1,1,0.1
                Rectangle:
                    size: self.size[0] + dp(50), self.size[1] + dp(2)
                    pos: self.pos[0] - dp(25), self.pos[1] - dp(1)
                Color:
                    rgba: 0.11, 0.12, 0.18, 1
                Rectangle:
                    size: self.size[0] + dp(48), self.size[1] 
                    pos: self.pos[0] - dp(24), self.pos[1]
                    
            BoxLayout:
                orientation: 'vertical'
                pos_hint: {'center_x': 0.5, 'center_y': 0.35}
                Image:
                    size_hint: 0.5, 0.5
                    pos_hint: {'center_x': 0.5, 'center_y': 0}
                    source: 'assets/dashboard_down.png' if dashboard.state == 'down' else 'assets/dashboard_normal.png'
                    ToggleButton:
                        id: dashboard
                        size: self.parent.parent.size
                        pos: self.parent.parent.pos
                        group: "footer"
                        background_color: 0,0,0,0
                        disabled: True if self.state == 'down' else False
                        state: 'down'
                        on_release: app.root.get_screen('main').switch_tab('dashboard')
                Label:
                    pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                    size_hint_y: 0.5
                    text: "[b]DASHBOARD[/b]"
                    color: (1,1,1,1) if dashboard.state == 'normal' else (0.20, 0.11, 0.44, 1)
                    font_size: dp(10)
                    text_size: self.size
                    markup: True
                    halign: 'center'
                    valign: 'top'
                    
            BoxLayout:
                orientation: 'vertical'
                pos_hint: {'center_x': 0.5, 'center_y': 0.35}
                Image:
                    size_hint: 0.5, 0.5
                    pos_hint: {'center_x': 0.5, 'center_y': 0}
                    source: 'assets/product_down.png' if product.state == 'down' else 'assets/product_normal.png'
                    ToggleButton:
                        id: product
                        size: self.parent.parent.size
                        pos: self.parent.parent.pos
                        group: "footer"
                        background_color: 0,0,0,0
                        disabled: True if self.state == 'down' else False
                        on_release: app.root.get_screen('main').switch_tab('product')
                Label:
                    pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                    size_hint_y: 0.5
                    text: "[b]PRODUCT[/b]"
                    font_size: dp(10)
                    color: (1,1,1,1) if product.state == 'normal' else (0.20, 0.11, 0.44, 1)
                    text_size: self.size
                    markup: True
                    halign: 'center'
                    valign: 'top'
                    
            BoxLayout:
                orientation: 'vertical'
                pos_hint: {'center_x': 0.5, 'center_y': 0.6}
                Image:
                    size_hint: 0.5, 0.5
                    pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                    source: 'assets/sell.png'
                    canvas.before:
                        Color:
                            rgba: 0.4, 0.31, 0.85, 1
                        Ellipse:
                            size: self.parent.size
                            pos: self.pos[0] - self.size[0] // 2, self.pos[1] - self.size[1] // 2
                    ToggleButton:
                        id: sell
                        size: self.parent.parent.size
                        pos: self.parent.parent.pos
                        group: "footer"
                        background_color: 0,0,0,0
                        disabled: True if self.state == 'down' else False
                        on_release: app.root.get_screen('main').switch_tab('sell')
                Label:
                    pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                    size_hint_y: 0.5
                    text: "[b]SELL[/b]"
                    color: (1,1,1,1) if sell.state == 'normal' else (0.20, 0.11, 0.44, 1)
                    font_size: dp(10)
                    text_size: self.size
                    markup: True
                    halign: 'center'
                    valign: 'bottom'
                    
            BoxLayout:
                orientation: 'vertical'
                pos_hint: {'center_x': 0.5, 'center_y': 0.35}
                Image:
                    size_hint: 0.5, 0.5
                    pos_hint: {'center_x': 0.5, 'center_y': 0}
                    source: 'assets/service_down.png' if service.state == 'down' else 'assets/service_normal.png'
                    ToggleButton:
                        id: service
                        size: self.parent.parent.size
                        pos: self.parent.parent.pos
                        group: "footer"
                        background_color: 0,0,0,0
                        disabled: True if self.state == 'down' else False
                        on_release: app.root.get_screen('main').switch_tab('service')
                Label:
                    pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                    size_hint_y: 0.5
                    text: "[b]SERVICE[/b]"
                    color: (1,1,1,1) if service.state == 'normal' else (0.20, 0.11, 0.44, 1)
                    font_size: dp(10)
                    text_size: self.size
                    markup: True
                    halign: 'center'
                    valign: 'top'
                    
            BoxLayout:
                orientation: 'vertical'
                pos_hint: {'center_x': 0.5, 'center_y': 0.35}
                FloatLayout:
                    size_hint_y: 0.5
                    Image:
                        id: status_icon_img
                        size_hint: 1, 1
                        pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                        source: 'assets/person_down.png' if info.state == 'down' else 'assets/person_normal.png'
                    ToggleButton:
                        id: info
                        size_hint: 1, 1
                        pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                        group: "footer"
                        background_color: 0,0,0,0
                        disabled: True if self.state == 'down' else False
                        on_release: app.root.get_screen('main').switch_tab('info')
                    Label:
                        text: str(app.unread_count) if app.unread_count > 0 else ""
                        size_hint: None, None
                        size: dp(14), dp(14)
                        pos_hint: {'center_x': 0.75, 'center_y': 0.85}
                        font_size: sp(9)
                        bold: True
                        color: 1, 1, 1, 1
                        opacity: 1 if app.unread_count > 0 else 0
                        canvas.before:
                            Color:
                                rgba: 0.88, 0.25, 0.25, 1
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [dp(7)]
                Label:
                    pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                    size_hint_y: 0.5
                    text: "[b]STATUS[/b]"
                    color: (1,1,1,1) if info.state == 'normal' else (0.20, 0.11, 0.44, 1)
                    font_size: dp(10)
                    text_size: self.size
                    markup: True
                    halign: 'center'
                    valign: 'top'


# ==========================================
# DOMAIN: PRIMARY SCREENS (TABS)
# ==========================================

# -------------------------------
# TAB: Dashboard
# -------------------------------
<Dashboard>:
    ScrollView:
        size: root.size
        pos: root.pos
        do_scroll: False, True
        bar_width: 0
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: 1.5
            spacing: dp(10)
            GridLayout:
                rows: 2
                cols: 2
                spacing: dp(10)
                BoxLayout:
                    orientation: 'vertical'
                    spacing: dp(5)
                    canvas.before:
                        Color:
                            rgba: 0.11, 0.12, 0.18, 1
                        RoundedRectangle:
                            size: self.size
                            pos: self.pos
                            radius: [10]
                    Label:
                        size_hint_y: 0.1
                    BoxLayout:
                        orientation: 'horizontal'
                        Label:
                            size_hint_x: 0.1
                        Image:
                            source: 'assets/peso.png'
                            size_hint_x: 0.3
                            canvas.before:
                                Color:
                                    rgba: 0.15, 0.17, 0.23, 0.5
                                RoundedRectangle:
                                    size: self.size
                                    pos: self.pos
                        Label:
                            size_hint_x: 0.1
                        Label:
                            id: earnings_trend
                            size_hint_x: 0.3
                            text: '+0%' 
                            markup: True
                            font_size: dp(12)
                            text_size: self.size
                            halign: 'center'
                            valign: 'center'
                            canvas.before:
                                Color:
                                    rgba: 0.15, 0.17, 0.23, 0.5
                                RoundedRectangle:
                                    size: self.size
                                    pos: self.pos
                        Label:
                            size_hint_x: 0.1
                    Label:
                        id: earnings_label
                        text: root.total_earnings
                        font_size: dp(16)
                        text_size: self.size
                        markup: True
                        halign: 'center'
                    Label:
                        text: 'Total Earnings'
                        font_size: dp(10)
                        text_size: self.size
                        halign: 'center'
                        valign: 'top'
                BoxLayout:
                    orientation: 'vertical'
                    spacing: dp(5)
                    canvas.before:
                        Color:
                            rgba: 0.11, 0.12, 0.18, 1
                        RoundedRectangle:
                            size: self.size
                            pos: self.pos
                            radius: [10]
                    Label:
                        size_hint_y: 0.1
                    BoxLayout:
                        orientation: 'horizontal'
                        Label:
                            size_hint_x: 0.1
                        Image:
                            source: 'assets/active_listing.png'
                            size_hint_x: 0.3
                            canvas.before:
                                Color:
                                    rgba: 0.15, 0.17, 0.23, 0.5
                                RoundedRectangle:
                                    size: self.size
                                    pos: self.pos
                        Label:
                            size_hint_x: 0.1
                        Label:
                            id: listings_trend
                            size_hint_x: 0.3
                            text: '+0%' 
                            markup: True
                            font_size: dp(12)
                            text_size: self.size
                            halign: 'center'
                            valign: 'center'
                            canvas.before:
                                Color:
                                    rgba: 0.15, 0.17, 0.23, 0.5
                                RoundedRectangle:
                                    size: self.size
                                    pos: self.pos
                        Label:
                            size_hint_x: 0.1
                    Label:
                        id: active_listings_label
                        text: root.active_listings
                        font_size: dp(16)
                        text_size: self.size
                        markup: True
                        halign: 'center'
                    Label:
                        text: 'Active Listing'
                        font_size: dp(10)
                        text_size: self.size
                        halign: 'center'
                        valign: 'top'
                BoxLayout:
                    orientation: 'vertical'
                    spacing: dp(5)
                    canvas.before:
                        Color:
                            rgba: 0.11, 0.12, 0.18, 1
                        RoundedRectangle:
                            size: self.size
                            pos: self.pos
                            radius: [10]
                    Label:
                        size_hint_y: 0.1
                    BoxLayout:
                        orientation: 'horizontal'
                        Label:
                            size_hint_x: 0.1
                        Image:
                            source: 'assets/sold.png'
                            size_hint_x: 0.3
                            canvas.before:
                                Color:
                                    rgba: 0.15, 0.17, 0.23, 0.5
                                RoundedRectangle:
                                    size: self.size
                                    pos: self.pos
                        Label:
                            size_hint_x: 0.1
                        Label:
                            id: sold_trend
                            size_hint_x: 0.3
                            text: '+0%' 
                            markup: True
                            font_size: dp(12)
                            text_size: self.size
                            halign: 'center'
                            valign: 'center'
                            canvas.before:
                                Color:
                                    rgba: 0.15, 0.17, 0.23, 0.5
                                RoundedRectangle:
                                    size: self.size
                                    pos: self.pos
                        Label:
                            size_hint_x: 0.1
                    Label:
                        id: items_sold_label
                        text: root.items_sold
                        font_size: dp(16)
                        text_size: self.size
                        markup: True
                        halign: 'center'
                    Label:
                        text: 'Item Sold'
                        font_size: dp(10)
                        text_size: self.size
                        halign: 'center'
                        valign: 'top'
                BoxLayout:
                    orientation: 'vertical'
                    spacing: dp(5)
                    canvas.before:
                        Color:
                            rgba: 0.11, 0.12, 0.18, 1
                        RoundedRectangle:
                            size: self.size
                            pos: self.pos
                            radius: [10]
                    Label:
                        size_hint_y: 0.1
                    BoxLayout:
                        orientation: 'horizontal'
                        Label:
                            size_hint_x: 0.1
                        Image:
                            source: 'assets/star-hallow.png'
                            size_hint_x: 0.3
                            canvas.before:
                                Color:
                                    rgba: 0.15, 0.17, 0.23, 0.5
                                RoundedRectangle:
                                    size: self.size
                                    pos: self.pos
                        Label:
                            size_hint_x: 0.1
                        Label:
                            id: rating_trend
                            size_hint_x: 0.3
                            text: 'Top 5%' 
                            markup: True
                            font_size: dp(12)
                            text_size: self.size
                            color: 1, 0.8, 0.2, 1
                            halign: 'center'
                            valign: 'center'
                            canvas.before:
                                Color:
                                    rgba: 0.15, 0.17, 0.23, 0.5
                                RoundedRectangle:
                                    size: self.size
                                    pos: self.pos
                        Label:
                            size_hint_x: 0.1
                    Label:
                        id: rating_label
                        text: root.seller_rating
                        font_size: dp(16)
                        text_size: self.size
                        markup: True
                        halign: 'center'
                    Label:
                        text: 'Seller Rating'
                        font_size: dp(10)
                        text_size: self.size
                        halign: 'center'
                        valign: 'top'
            BoxLayout:
                id: graph
                orientation: 'vertical'
                canvas.before:
                    Color:
                        rgba: 0.11, 0.12, 0.18, 1
                    RoundedRectangle:
                        size: self.size
                        pos: self.pos
                        radius: [10]
                Label:
                    size_hint_y: 0.05
                BoxLayout:
                    size_hint: 0.9, 0.2
                    pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                    spacing: dp(5)
                    orientation: 'horizontal'
                    BoxLayout:
                        orientation: 'horizontal'
                        Label:
                            text: '[b]EARNINGS[/b]'
                            markup: True
                            text_size: self.size
                            halign: 'center'
                            valign: 'center'
                ScrollView:
                    size_hint: 0.9, 0.3
                    pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                    id: scroll
                    do_scroll_y: False
                    bar_width: 0
                    Widget:
                        id: chart
                        size_hint_x: None
                        height: root.height
                        width: 100
                        canvas:
                            Color:
                                rgba: 0.11, 0.12, 0.18, 1
                            Rectangle:
                                pos: self.pos
                                size: self.size
                Label:
                    size_hint: 0.9, 0.2   
                    pos_hint: {'center_x': 0.5, 'center_y': 0.5}
            Label:
                size_hint_y: 0.2
                text: '[b]RECENT ACTIVITY[/b]'
                markup: True
                text_size: self.size
                valign: 'center'
                halign: 'left'
            ScrollView:
                do_scroll: False, True
                size_hint_y: 1
                BoxLayout:
                    id: recent_activity_list
                    orientation: 'vertical'
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: dp(10)
                    padding: [0, dp(5), 0, dp(100)]
            Label:
                size_hint_y: 0.05

# -------------------------------
# TAB: Marketplace (Product)
# -------------------------------
<Product>:
    BoxLayout:
        size: root.size
        pos: root.pos
        orientation: 'vertical'
        spacing: dp(5)
        Label:
            size_hint_y: 0.01
        BoxLayout:
            size_hint: 0.95, None
            height: dp(50)
            pos_hint: {'center_x': 0.5}
            padding: [0, dp(5), 0, dp(5)]
            BoxLayout:
                size_hint_y: None
                height: self.parent.height
                padding: [dp(15), 0]
                canvas.before:
                    Color:
                        rgba: 0.15, 0.16, 0.22, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(15)]
                TextInput:
                    id: search_bar
                    hint_text: 'Search for textbooks, notes...'
                    size_hint_y: None
                    height: self.minimum_height
                    pos_hint: {'center_y': 0.5}
                    background_normal: ''
                    background_active: ''
                    background_color: 0, 0, 0, 0
                    foreground_color: 1, 1, 1, 1
                    hint_text_color: 0.5, 0.5, 0.5, 1
                    multiline: False
                    padding: [0, 0]
                    on_text: root.filter_products()
        BoxLayout:
            size_hint_y: None
            height: dp(60)
            pos_hint: {'center_x': 0.5}
            spacing: dp(10)
            orientation: 'horizontal'
            padding: [0, dp(10), 0, dp(10)]
            ScrollView:
                size_hint_y: None
                height: dp(40)
                pos_hint: {'center_y': 0.5}
                do_scroll: True, False
                bar_width: 0
                scroll_timeout: 250
                scroll_distance: dp(20)
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_x: None
                    width: self.minimum_width
                    padding: [dp(20), 0]
                    spacing: dp(10)
                    ToggleButton:
                        group: 'products'
                        state: 'down'
                        text: 'All'
                        size_hint_x: None
                        width: dp(60)
                        font_size: sp(14)
                        bold: True
                        background_color: 0,0,0,0
                        color: (1, 1, 1, 1) if self.state == 'down' else (1, 1, 1, 0.5)
                        on_release: root.set_category('All')
                        canvas.before:
                            Color:
                                rgba: (0.42, 0.35, 0.88, 1) if self.state == 'down' else (0.11, 0.13, 0.18, 1)
                            RoundedRectangle:
                                size: self.size
                                pos: self.pos
                                radius: [dp(20)]
                    ToggleButton:
                        group: 'products'
                        text: 'Textbooks'
                        size_hint_x: None
                        width: dp(100)
                        font_size: sp(14)
                        bold: True
                        background_color: 0,0,0,0
                        color: (1, 1, 1, 1) if self.state == 'down' else (1, 1, 1, 0.5)
                        on_release: root.set_category('Textbooks')
                        canvas.before:
                            Color:
                                rgba: (0.42, 0.35, 0.88, 1) if self.state == 'down' else (0.11, 0.13, 0.18, 1)
                            RoundedRectangle:
                                size: self.size
                                pos: self.pos
                                radius: [dp(20)]
                    ToggleButton:
                        group: 'products'
                        text: 'Notes'
                        size_hint_x: None
                        width: dp(70)
                        font_size: sp(14)
                        bold: True
                        background_color: 0,0,0,0
                        color: (1, 1, 1, 1) if self.state == 'down' else (1, 1, 1, 0.5)
                        on_release: root.set_category('Notes')
                        canvas.before:
                            Color:
                                rgba: (0.42, 0.35, 0.88, 1) if self.state == 'down' else (0.11, 0.13, 0.18, 1)
                            RoundedRectangle:
                                size: self.size
                                pos: self.pos
                                radius: [dp(20)]
                    ToggleButton:
                        group: 'products'
                        text: 'Guidelines'
                        size_hint_x: None
                        width: dp(100)
                        font_size: sp(14)
                        bold: True
                        background_color: 0,0,0,0
                        color: (1, 1, 1, 1) if self.state == 'down' else (1, 1, 1, 0.5)
                        on_release: root.set_category('Guidelines')
                        canvas.before:
                            Color:
                                rgba: (0.42, 0.35, 0.88, 1) if self.state == 'down' else (0.11, 0.13, 0.18, 1)
                            RoundedRectangle:
                                size: self.size
                                pos: self.pos
                                radius: [dp(20)]
                    ToggleButton:
                        group: 'products'
                        text: 'Materials'
                        size_hint_x: None
                        width: dp(90)
                        font_size: sp(14)
                        bold: True
                        background_color: 0,0,0,0
                        color: (1, 1, 1, 1) if self.state == 'down' else (1, 1, 1, 0.5)
                        on_release: root.set_category('Materials')
                        canvas.before:
                            Color:
                                rgba: (0.42, 0.35, 0.88, 1) if self.state == 'down' else (0.11, 0.13, 0.18, 1)
                            RoundedRectangle:
                                size: self.size
                                pos: self.pos
                                radius: [dp(20)]
        ScrollView:
            id: scroll
            do_scroll: False, True
            BoxLayout:
                id: dynamic_product
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(15)
                padding: [0, dp(10), 0, dp(100)]
        Label:
            size_hint_y: 0.01

# -------------------------------
# TAB: Create Listing (Sell)
# -------------------------------
<Sell>:
    ScrollView:
        size: root.size
        pos: root.pos
        do_scroll: False, True
        bar_width: 0
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height
            padding: [dp(20), dp(40), dp(20), dp(100)] 
            spacing: dp(24)
            
            EscrowBanner:
            
            BoxLayout:
                size_hint_y: None
                height: dp(50)
                spacing: dp(15)
                canvas.before:
                    Color:
                        rgba: 0.11, 0.12, 0.16, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(12)]
                ToggleButton:
                    text: '[b]Product[/b]'
                    markup: True
                    group: 'main_sell_mode'
                    state: 'down'
                    allow_no_selection: False
                    background_color: 0,0,0,0
                    color: (1,1,1,1) if self.state == 'down' else (0.5,0.5,0.5,1)
                    on_state: root.is_service_mode = False if self.state == 'down' else True
                    canvas.before:
                        Color:
                            rgba: (0.42, 0.35, 0.88, 1) if self.state == 'down' else (0,0,0,0)
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(12)]
                ToggleButton:
                    text: '[b]Service[/b]'
                    markup: True
                    group: 'main_sell_mode'
                    allow_no_selection: False
                    background_color: 0,0,0,0
                    color: (1,1,1,1) if self.state == 'down' else (0.5,0.5,0.5,1)
                    canvas.before:
                        Color:
                            rgba: (0.42, 0.35, 0.88, 1) if self.state == 'down' else (0,0,0,0)
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(12)]
            
            FormInput:
                id: title_input
                title: 'Title'
                hint: 'e.g. Organic Chemistry 8th Edition'
                multilined: False
            FormInput:
                id: subject_input
                title: 'Subject'
                hint: 'e.g. Mathematics, History, Biology'
                multilined: False
            FormInput:
                id: desc_input
                title: 'Description'
                hint: 'Provide details about your listing...'
                height: dp(120)
                multilined: True
            FormInput:
                id: price_input
                title: 'Price'
                hint: ' 0.00' if not root.is_service_mode else ' 0.00 (Base Rate)'
                multilined: False
                
            FloatLayout:
                size_hint_y: None
                height: dp(160)
                
                # LAYER A: PRODUCT SETTINGS
                BoxLayout:
                    orientation: 'vertical'
                    pos_hint: {'x': 0, 'y': 0} if not root.is_service_mode else {'x': 50, 'y': 0}
                    size_hint: 1, 1
                    spacing: dp(10)
                    opacity: 1 if not root.is_service_mode else 0
                    disabled: True if root.is_service_mode else False
                    Label:
                        text: 'Product Type'
                        bold: True
                        font_size: sp(14)
                        size_hint_y: None
                        height: dp(20)
                        text_size: self.size
                        halign: 'left'
                    ScrollView:
                        do_scroll: True, False
                        bar_width: 0
                        size_hint_y: None
                        height: dp(40)
                        BoxLayout:
                            id: product_type_group
                            orientation: 'horizontal'
                            size_hint_x: None
                            width: self.minimum_width
                            spacing: dp(8)
                            SelectionBadge:
                                group: 'prod_type'
                                text: 'Textbooks'
                                width: dp(100)
                                state: 'down'
                            SelectionBadge:
                                group: 'prod_type'
                                text: 'Notes'
                                width: dp(80)
                            SelectionBadge:
                                group: 'prod_type'
                                text: 'Guidelines'
                                width: dp(100)
                            SelectionBadge:
                                group: 'prod_type'
                                text: 'Materials'
                                width: dp(100)
                    Label:
                        text: 'Condition'
                        bold: True
                        font_size: sp(14)
                        size_hint_y: None
                        height: dp(20)
                        text_size: self.size
                        halign: 'left'
                    ScrollView:
                        do_scroll: True, False
                        bar_width: 0
                        size_hint_y: None
                        height: dp(40)
                        BoxLayout:
                            id: condition_group
                            orientation: 'horizontal'
                            size_hint_x: None
                            width: self.minimum_width
                            spacing: dp(8)
                            ToggleButton:
                                group: 'cond'
                                state: 'down'
                                text: 'New'
                                size_hint_x: None
                                width: dp(70)
                                background_color: 0,0,0,0
                                canvas.before:
                                    Color:
                                        rgba: (0.42, 0.35, 0.88, 0.2) if self.state == 'down' else (1,1,1,0.05)
                                    RoundedRectangle:
                                        pos: self.pos
                                        size: self.size
                                        radius: [dp(12)]
                            ToggleButton:
                                group: 'cond'
                                text: 'Good'
                                size_hint_x: None
                                width: dp(70)
                                background_color: 0,0,0,0
                                canvas.before:
                                    Color:
                                        rgba: (0.42, 0.35, 0.88, 0.2) if self.state == 'down' else (1,1,1,0.05)
                                    RoundedRectangle:
                                        pos: self.pos
                                        size: self.size
                                        radius: [dp(12)]
                            ToggleButton:
                                group: 'cond'
                                text: 'Digital'
                                size_hint_x: None
                                width: dp(80)
                                background_color: 0,0,0,0
                                canvas.before:
                                    Color:
                                        rgba: (0.42, 0.35, 0.88, 0.2) if self.state == 'down' else (1,1,1,0.05)
                                    RoundedRectangle:
                                        pos: self.pos
                                        size: self.size
                                        radius: [dp(12)]
                                        
                # LAYER B: SERVICE SETTINGS
                BoxLayout:
                    orientation: 'vertical'
                    pos_hint: {'x': 0, 'y': 0} if root.is_service_mode else {'x': 50, 'y': 0}
                    size_hint: 1, 1
                    spacing: dp(10)
                    opacity: 1 if root.is_service_mode else 0
                    disabled: True if not root.is_service_mode else False
                    Label:
                        text: 'Service Type'
                        bold: True
                        font_size: sp(14)
                        size_hint_y: None
                        height: dp(20)
                        text_size: self.size
                        halign: 'left'
                    ScrollView:
                        do_scroll: True, False
                        bar_width: 0
                        size_hint_y: None
                        height: dp(40)
                        BoxLayout:
                            id: service_type_group
                            orientation: 'horizontal'
                            size_hint_x: None
                            width: self.minimum_width
                            spacing: dp(8)
                            SelectionBadge:
                                group: 'srv_type'
                                text: 'Tutoring'
                                width: dp(90)
                                state: 'down'
                            SelectionBadge:
                                group: 'srv_type'
                                text: 'Writing'
                                width: dp(80)
                            SelectionBadge:
                                group: 'srv_type'
                                text: 'Career'
                                width: dp(80)
                            SelectionBadge:
                                group: 'srv_type'
                                text: 'Test Prep'
                                width: dp(100)
                    Label:
                        text: 'Rate Format'
                        bold: True
                        font_size: sp(14)
                        size_hint_y: None
                        height: dp(20)
                        text_size: self.size
                        halign: 'left'
                    ScrollView:
                        do_scroll: True, False
                        bar_width: 0
                        size_hint_y: None
                        height: dp(40)
                        BoxLayout:
                            id: rate_group
                            orientation: 'horizontal'
                            size_hint_x: None
                            width: self.minimum_width
                            spacing: dp(8)
                            ToggleButton:
                                group: 'rate'
                                state: 'down'
                                text: '/hr'
                                size_hint_x: None
                                width: dp(60)
                                background_color: 0,0,0,0
                                canvas.before:
                                    Color:
                                        rgba: (0.42, 0.35, 0.88, 0.2) if self.state == 'down' else (1,1,1,0.05)
                                    RoundedRectangle:
                                        pos: self.pos
                                        size: self.size
                                        radius: [dp(12)]
                            ToggleButton:
                                group: 'rate'
                                text: '/week'
                                size_hint_x: None
                                width: dp(80)
                                background_color: 0,0,0,0
                                canvas.before:
                                    Color:
                                        rgba: (0.42, 0.35, 0.88, 0.2) if self.state == 'down' else (1,1,1,0.05)
                                    RoundedRectangle:
                                        pos: self.pos
                                        size: self.size
                                        radius: [dp(12)]
                            ToggleButton:
                                group: 'rate'
                                text: '/month'
                                size_hint_x: None
                                width: dp(90)
                                background_color: 0,0,0,0
                                canvas.before:
                                    Color:
                                        rgba: (0.42, 0.35, 0.88, 0.2) if self.state == 'down' else (1,1,1,0.05)
                                    RoundedRectangle:
                                        pos: self.pos
                                        size: self.size
                                        radius: [dp(12)]
            PrimaryButton:
                id: publish_btn
                text: '[b]Publish Listing[/b]'
                on_release: root.add_product()

# -------------------------------
# TAB: Freelance (Service)
# -------------------------------
<Service>:
    BoxLayout:
        size: root.size
        pos: root.pos
        orientation: 'vertical'
        spacing: dp(5)
        Label:
            size_hint_y: 0.01
        BoxLayout:
            size_hint: 0.95, None
            height: dp(50)
            pos_hint: {'center_x': 0.5}
            padding: [0, dp(5), 0, dp(5)]
            BoxLayout:
                size_hint_y: None
                height: self.parent.height
                padding: [dp(15), 0]
                canvas.before:
                    Color:
                        rgba: 0.15, 0.16, 0.22, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(15)]
                TextInput:
                    id: search_bar
                    hint_text: 'Search for tutors, writers, guides...'
                    size_hint_y: None
                    height: self.minimum_height
                    pos_hint: {'center_y': 0.5}
                    background_normal: ''
                    background_active: ''
                    background_color: 0, 0, 0, 0
                    foreground_color: 1, 1, 1, 1
                    hint_text_color: 0.5, 0.5, 0.5, 1
                    multiline: False
                    padding: [0, 0]
                    on_text: root.filter_services()
        BoxLayout:
            size_hint_y: None
            height: dp(60)
            pos_hint: {'center_x': 0.5}
            spacing: dp(10)
            orientation: 'horizontal'
            padding: [0, dp(10), 0, dp(10)]
            ScrollView:
                size_hint_y: None
                height: dp(40)
                pos_hint: {'center_y': 0.5}
                do_scroll: True, False
                bar_width: 0
                scroll_timeout: 250
                scroll_distance: dp(20)
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_x: None
                    width: self.minimum_width
                    padding: [dp(20), 0]
                    spacing: dp(10)
                    ToggleButton:
                        group: 'services'
                        state: 'down'
                        text: 'All'
                        size_hint_x: None
                        width: dp(60)
                        font_size: sp(14)
                        bold: True
                        background_color: 0,0,0,0
                        color: (1, 1, 1, 1) if self.state == 'down' else (1, 1, 1, 0.5)
                        on_release: root.set_category('All')
                        canvas.before:
                            Color:
                                rgba: (0.42, 0.35, 0.88, 1) if self.state == 'down' else (0.11, 0.13, 0.18, 1)
                            RoundedRectangle:
                                size: self.size
                                pos: self.pos
                                radius: [dp(20)]
                    ToggleButton:
                        group: 'services'
                        text: 'Tutoring'
                        size_hint_x: None
                        width: dp(90)
                        font_size: sp(14)
                        bold: True
                        background_color: 0,0,0,0
                        color: (1, 1, 1, 1) if self.state == 'down' else (1, 1, 1, 0.5)
                        on_release: root.set_category('Tutoring')
                        canvas.before:
                            Color:
                                rgba: (0.42, 0.35, 0.88, 1) if self.state == 'down' else (0.11, 0.13, 0.18, 1)
                            RoundedRectangle:
                                size: self.size
                                pos: self.pos
                                radius: [dp(20)]
                    ToggleButton:
                        group: 'services'
                        text: 'Writing'
                        size_hint_x: None
                        width: dp(80)
                        font_size: sp(14)
                        bold: True
                        background_color: 0,0,0,0
                        color: (1, 1, 1, 1) if self.state == 'down' else (1, 1, 1, 0.5)
                        on_release: root.set_category('Writing')
                        canvas.before:
                            Color:
                                rgba: (0.42, 0.35, 0.88, 1) if self.state == 'down' else (0.11, 0.13, 0.18, 1)
                            RoundedRectangle:
                                size: self.size
                                pos: self.pos
                                radius: [dp(20)]
                    ToggleButton:
                        group: 'services'
                        text: 'Career'
                        size_hint_x: None
                        width: dp(80)
                        font_size: sp(14)
                        bold: True
                        background_color: 0,0,0,0
                        color: (1, 1, 1, 1) if self.state == 'down' else (1, 1, 1, 0.5)
                        on_release: root.set_category('Career')
                        canvas.before:
                            Color:
                                rgba: (0.42, 0.35, 0.88, 1) if self.state == 'down' else (0.11, 0.13, 0.18, 1)
                            RoundedRectangle:
                                size: self.size
                                pos: self.pos
                                radius: [dp(20)]
                    ToggleButton:
                        group: 'services'
                        text: 'Test Prep'
                        size_hint_x: None
                        width: dp(100)
                        font_size: sp(14)
                        bold: True
                        background_color: 0,0,0,0
                        color: (1, 1, 1, 1) if self.state == 'down' else (1, 1, 1, 0.5)
                        on_release: root.set_category('Test Prep')
                        canvas.before:
                            Color:
                                rgba: (0.42, 0.35, 0.88, 1) if self.state == 'down' else (0.11, 0.13, 0.18, 1)
                            RoundedRectangle:
                                size: self.size
                                pos: self.pos
                                radius: [dp(20)]
        ScrollView:
            id: scroll
            do_scroll: False, True
            BoxLayout:
                id: dynamic_service
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(15)
                padding: [0, dp(10), 0, dp(100)]
        Label:
            size_hint_y: 0.01

# -------------------------------
# TAB: Status & Account Menu
# -------------------------------
<Status>:
    canvas.before:
        Color:
            rgba: 0,0,0,0
        Rectangle:
            pos: self.pos
            size: self.size
    ScreenManager:
        size: root.size
        pos: root.pos
        id: screenmanager
        Screen:
            name: 'menu'
            BoxLayout:
                orientation: 'vertical'
                size: root.size
                pos: root.pos
                ScrollView:
                    do_scroll: False, True
                    bar_width: 0
                    BoxLayout:
                        orientation: 'vertical'
                        size_hint_y: None
                        height: self.minimum_height
                        padding: dp(20)
                        spacing: dp(30)
                        BoxLayout:
                            orientation: 'vertical'
                            size_hint_y: None
                            height: self.minimum_height
                            spacing: dp(10)
                            FloatLayout:
                                size_hint: None, None
                                size: dp(100), dp(100)
                                pos_hint: {'center_x': 0.5}
                                canvas.before:
                                    Color:
                                        rgba: 0.12, 0.13, 0.20, 1
                                    Ellipse:
                                        pos: self.pos
                                        size: self.size
                                Label:
                                    text: f'[b]{root.initial}[/b]'
                                    markup: True
                                    font_size: sp(36)
                                    color: 0.4, 0.31, 0.85, 1 
                                    pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                                FloatLayout:
                                    size_hint: None, None
                                    size: dp(32), dp(32)
                                    pos_hint: {'right': 1.0, 'y': 0}
                                    canvas.before:
                                        Color:
                                            rgba: 0.4, 0.31, 0.85, 1
                                        Ellipse:
                                            pos: self.pos
                                            size: self.size
                                    Image:
                                        source: 'assets/camera.png'
                                        size_hint: 0.5, 0.5
                                        pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                            Label:
                                text: f'[b]{root.full_name}[/b]'
                                markup: True
                                font_size: sp(22)
                                size_hint_y: None
                                height: dp(30)
                                color: 1, 1, 1, 1
                            Label:
                                text: f'{root.email}' 
                                font_size: sp(14)
                                size_hint_y: None
                                height: dp(20)
                                color: 0.6, 0.6, 0.6, 1
                            BoxLayout:
                                orientation: 'horizontal'
                                size_hint: None, None
                                height: dp(35)
                                width: self.minimum_width
                                pos_hint: {'center_x': 0.5}
                                spacing: dp(10)
                                BoxLayout:
                                    size_hint_x: None
                                    width: dp(95)
                                    padding: [dp(10), dp(5), dp(10), dp(5)]
                                    spacing: dp(5)
                                    canvas.before:
                                        Color:
                                            rgba: 0.10, 0.15, 0.15, 1
                                        RoundedRectangle:
                                            pos: self.pos
                                            size: self.size
                                            radius: [dp(15)]
                                        Color:
                                            rgba: 0.2, 0.8, 0.4, 0.5 
                                        Line:
                                            rounded_rectangle: [self.x, self.y, self.width, self.height, dp(15)]
                                            width: dp(1)
                                    Image:
                                        source: 'assets/green_shield.png'
                                        size_hint_x: None
                                        width: dp(15)
                                    Label:
                                        text: 'Verified'
                                        color: 0.2, 0.8, 0.4, 1
                                        font_size: sp(12)
                                        bold: True
                                BoxLayout:
                                    size_hint_x: None
                                    width: dp(75)
                                    padding: [dp(10), dp(5), dp(10), dp(5)]
                                    spacing: dp(5)
                                    canvas.before:
                                        Color:
                                            rgba: 0.15, 0.12, 0.20, 1 
                                        RoundedRectangle:
                                            pos: self.pos
                                            size: self.size
                                            radius: [dp(15)]
                                        Color:
                                            rgba: 0.4, 0.31, 0.85, 0.5 
                                        Line:
                                            rounded_rectangle: [self.x, self.y, self.width, self.height, dp(15)]
                                            width: dp(1)
                                    Image:
                                        source: 'assets/star.png'
                                        size_hint_x: None
                                        width: dp(15)
                                    Label:
                                        text: root.rating
                                        color: 0.4, 0.31, 0.85, 1
                                        font_size: sp(12)
                                        bold: True
                        BoxLayout:
                            orientation: 'vertical'
                            size_hint_y: None
                            height: self.minimum_height
                            spacing: dp(5)
                            MenuItem:
                                icon_source: 'assets/profile.png'
                                text: 'My Profile'
                                on_release: 
                                    screenmanager.current = 'profile'
                                    screenmanager.get_screen('profile').children[0].load_info()
                                    root.parent.parent.parent.parent.ids.label1.text = '[b]MY PROFILE[/b]'
                                    root.parent.parent.parent.parent.ids.label2.text = 'view your details'
                                    root.parent.parent.parent.parent.ids.back_btn.opacity = 1
                                    root.parent.parent.parent.parent.ids.back_btn.disabled = False
                                    app.root.get_screen('main').toggle_footer(False)
                            MenuItem:
                                icon_source: 'assets/chat.png'
                                text: 'Inbox'
                                badge_count: app.unread_count
                                on_release: 
                                    screenmanager.current = 'inbox'
                                    screenmanager.get_screen('inbox').children[0].load_hub_data()
                                    root.parent.parent.parent.parent.ids.label1.text = '[b]INBOX[/b]'
                                    root.parent.parent.parent.parent.ids.label2.text = 'Your active conversations'
                                    root.parent.parent.parent.parent.ids.back_btn.opacity = 1
                                    root.parent.parent.parent.parent.ids.back_btn.disabled = False
                                    app.root.get_screen('main').toggle_footer(False)
                            MenuItem:
                                icon_source: 'assets/wallet.png'
                                text: 'Wallet'
                                on_release: 
                                    screenmanager.current = 'wallet'
                                    root.parent.parent.parent.parent.ids.label1.text = '[b]WALLET[/b]'
                                    screenmanager.get_screen('wallet').children[0].load_balance()
                                    root.parent.parent.parent.parent.ids.label2.text = 'manage your funds'
                                    root.parent.parent.parent.parent.ids.back_btn.opacity = 1
                                    root.parent.parent.parent.parent.ids.back_btn.disabled = False
                                    app.root.get_screen('main').toggle_footer(False)
                            MenuItem:
                                icon_source: 'assets/settings.png'
                                text: 'Settings'
                                on_release: 
                                    screenmanager.current = 'settings'
                                    root.parent.parent.parent.parent.ids.label1.text = '[b]SETTINGS[/b]'
                                    root.parent.parent.parent.parent.ids.label2.text = 'manage your preferences'
                                    root.parent.parent.parent.parent.ids.back_btn.opacity = 1
                                    root.parent.parent.parent.parent.ids.back_btn.disabled = False
                                    app.root.get_screen('main').toggle_footer(False)
                            MenuItem:
                                icon_source: 'assets/logout.png'
                                text: 'Sign Out'
                                text_color: 0.8, 0.2, 0.2, 1 
                                icon_bg_color: 0.15, 0.05, 0.05, 1 
                                on_release: 
                                    screenmanager.current = 'logout'
                                    root.parent.parent.parent.parent.ids.label1.text = '[b]SIGN OUT[/b]'
                                    root.parent.parent.parent.parent.ids.label2.text = 'disconnect securely'
                                    root.parent.parent.parent.parent.ids.back_btn.opacity = 1
                                    root.parent.parent.parent.parent.ids.back_btn.disabled = False
                                    app.root.get_screen('main').toggle_footer(False)
        Screen:
            name: 'profile'
            Profile:
                size: root.size
                pos: root.pos
        Screen:
            name: 'inbox'
            InboxScreen:
        Screen:
            name: 'chatbox'
            ChatBox:
                size: root.size
                pos: root.pos
        Screen:
            name: 'settings'
            UserSettings:
        Screen:
            name: 'wallet'
            Wallet:
                size: root.size
                pos: root.pos
        Screen:
            name: 'logout'
            LogOut:
                size: root.size
                pos: root.pos

# ==========================================
# DOMAIN: SUB-SCREENS & PAGES
# ==========================================

# -------------------------------
# PAGE: Profile UI Elements
# -------------------------------
<ProfileDataTile@BoxLayout>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(80) 
    padding: [dp(15), 0]
    spacing: dp(15)
    canvas.before:
        Color:
            rgba: 0.11, 0.12, 0.16, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(15)]
    icon_source: ''
    title: ''
    subtitle: ''
    FloatLayout:
        size_hint: None, None
        size: dp(50), dp(50)
        pos_hint: {'center_y': 0.5}
        canvas.before:
            Color:
                rgba: 0.12, 0.13, 0.20, 1
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(10)]
        Image:
            id: tile_icon
            source: root.icon_source
            size_hint: 0.6, 0.6
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
    BoxLayout:
        orientation: 'vertical'
        spacing: dp(5)
        pos_hint: {'center_y': 0.5}
        Label:
            text: root.title
            id: title_lbl
            font_size: sp(16)
            bold: True
            color: 1, 1, 1, 1
            text_size: self.size
            halign: 'left'
            valign: 'bottom'
        Label:
            text: root.subtitle
            id: subtitle_lbl
            font_size: sp(13)
            color: 0.7, 0.7, 0.7, 1
            text_size: self.size
            halign: 'left'
            valign: 'top'
            shorten: True
            shorten_from: 'right'

<Profile>:
    size: root.size
    pos: root.pos
    orientation: 'vertical'
    padding: [dp(20), dp(5), dp(20), dp(20)]
    spacing: dp(15)
    ScrollView:
        do_scroll: False, True
        bar_width: 0
        scroll_timeout: 250
        scroll_distance: dp(20)
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height
            spacing: dp(15)
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: dp(160)
                spacing: dp(5)
                FloatLayout:
                    size_hint: None, None
                    size: dp(90), dp(90)
                    pos_hint: {'center_x': 0.5}
                    canvas.before:
                        Color:
                            rgba: 0.12, 0.13, 0.20, 1
                        Ellipse:
                            pos: self.pos
                            size: self.size
                    Label:
                        id: initial_label
                        text: '[b]-[/b]'
                        markup: True
                        font_size: sp(32)
                        color: 0.43, 0.33, 0.85, 1
                        pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                Label:
                    id: display_name_label
                    text: '[b]Loading...[/b]'
                    markup: True
                    font_size: sp(22)
                    size_hint_y: None
                    height: dp(30)
                Label:
                    id: display_email_label 
                    text: '...'
                    font_size: sp(14)
                    color: 0.6, 0.6, 0.6, 1
                    size_hint_y: None
                    height: dp(20)
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(10)
                ProfileDataTile:
                    id: tile_email
                    icon_source: 'assets/email.png'
                    title: 'Email'
                    subtitle: 'loading...'
                ProfileDataTile:
                    id: tile_role
                    icon_source: 'assets/school.png'
                    title: 'Role'
                    subtitle: 'loading...'
                ProfileDataTile:
                    id: tile_age
                    icon_source: 'assets/age.png' 
                    title: 'Age'
                    subtitle: 'loading...'
                ProfileDataTile:
                    id: tile_birthday
                    icon_source: 'assets/birthday.png' 
                    title: 'Birthday'
                    subtitle: 'loading...'
                ProfileDataTile:
                    id: tile_location
                    icon_source: 'assets/location.png' 
                    title: 'Location'
                    subtitle: 'loading...'
            Label:
                size_hint_y: None
                height: dp(15)
            EditProfileButton:
                text: 'Edit Profile'
                on_release: root.open_edit_modal()

# -------------------------------
# PAGE: Inbox & Chat UI
# -------------------------------
<InboxScreen>:
    orientation: 'vertical'
    padding: [dp(20), dp(5), dp(20), dp(20)]
    spacing: dp(15)
    BoxLayout:
        size_hint_y: None
        height: dp(40)
        spacing: dp(8)
        ToggleButton:
            text: 'Chats'
            group: 'hub_tabs'
            state: 'down'
            font_size: sp(12)
            background_color: 0,0,0,0
            color: (1,1,1,1) if self.state == 'down' else (1,1,1,0.5)
            on_release: root.switch_tab('chats')
            canvas.before:
                Color:
                    rgba: (0.42, 0.35, 0.88, 1) if self.state == 'down' else (0.11, 0.12, 0.16, 1)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(10)]
        ToggleButton:
            text: 'Products'
            group: 'hub_tabs'
            font_size: sp(12)
            background_color: 0,0,0,0
            color: (1,1,1,1) if self.state == 'down' else (1,1,1,0.5)
            on_release: root.switch_tab('products')
            canvas.before:
                Color:
                    rgba: (0.42, 0.35, 0.88, 1) if self.state == 'down' else (0.11, 0.12, 0.16, 1)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(10)]
        ToggleButton:
            text: 'Subs'
            group: 'hub_tabs'
            font_size: sp(12)
            background_color: 0,0,0,0
            color: (1,1,1,1) if self.state == 'down' else (1,1,1,0.5)
            on_release: root.switch_tab('subs')
            canvas.before:
                Color:
                    rgba: (0.42, 0.35, 0.88, 1) if self.state == 'down' else (0.11, 0.12, 0.16, 1)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(10)]
    ScrollView:
        do_scroll: False, True
        bar_width: 0
        BoxLayout:
            id: hub_list
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height
            spacing: dp(10)

<ChatBox>:
    size: root.size
    pos: root.pos
    orientation: 'vertical'
    BoxLayout:
        size_hint_y: None
        height: dp(60)
        padding: dp(10)
        spacing: dp(10)
        canvas.before:
            Color:
                rgba: 0.11, 0.12, 0.16, 1
            Rectangle:
                pos: self.pos
                size: self.size
        FloatLayout:
            size_hint: None, None
            size: dp(40), dp(40)
            canvas.before:
                Color:
                    rgba: 0.15, 0.12, 0.25, 1
                Ellipse:
                    pos: self.pos
                    size: self.size
            Label:
                id: chat_header_initials
                text: '[b]-[/b]'
                markup: True
                font_size: sp(16)
                color: 0.43, 0.33, 0.85, 1
                pos_hint: {'center_x': 0.5, 'center_y': 0.5}
        BoxLayout:
            orientation: 'vertical'
            Label:
                id: chat_header_name
                text: '[b]User[/b]'
                markup: True
                text_size: self.size
                halign: 'left'
                valign: 'bottom'
            Label:
                text: 'Online'
                color: 0.2, 0.8, 0.4, 1
                font_size: sp(12)
                text_size: self.size
                halign: 'left'
                valign: 'top'
    ScrollView:
        id: chat_scroll
        do_scroll: False, True
        scroll_timeout: 250
        scroll_distance: dp(20)
        BoxLayout:
            id: chat_history
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height
            padding: dp(15)
            spacing: dp(15)
    BoxLayout:
        size_hint_y: None
        height: dp(70)
        padding: dp(15)
        spacing: dp(10)
        canvas.before:
            Color:
                rgba: 0.11, 0.12, 0.16, 1
            Rectangle:
                pos: self.pos
                size: self.size
        IconButton:
            size_hint_x: None
            width: dp(30)
            icon_source: 'assets/attach.png'
            icon_size_hint: 0.8, 0.8
            on_release: print("Attach file triggered")
        TextInput:
            id: chat_input
            hint_text: 'Type a message...'
            background_color: 0,0,0,0
            foreground_color: 1,1,1,1
            hint_text_color: 0.5, 0.5, 0.5, 1
            multiline: False
            padding: [dp(15), dp(10)]
        SendButton:
            size_hint_x: None
            width: dp(50)
            on_release: root.send_new_message()

# -------------------------------
# PAGE: Wallet UI
# -------------------------------
<Wallet>:
    size: root.size
    pos: root.pos
    orientation: 'vertical'
    padding: [dp(20), dp(5), dp(20), dp(20)]
    spacing: dp(15)
    ScrollView:
        do_scroll: False, True
        bar_width: 0
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height
            spacing: dp(25)
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: dp(230)
                padding: dp(20)
                canvas.before:
                    Color:
                        rgba: 0.43, 0.33, 0.85, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(20)]
                Label:
                    text: 'Available Balance'
                    font_size: sp(14)
                    size_hint_y: None
                    height: dp(20)
                    text_size: self.size
                    halign: 'left'
                Label:
                    id: balance_label
                    text: f'[b]₱{root.current_balance}[/b]'
                    markup: True
                    font_size: sp(36)
                    size_hint_y: None
                    height: dp(50)
                    text_size: self.size
                    halign: 'left'
                TextInput:
                    id: amount_input
                    hint_text: 'Enter amount (e.g. 500)'
                    multiline: False
                    input_filter: 'float'
                    size_hint_y: None
                    height: dp(40)
                    background_color: 1, 1, 1, 0.1
                    foreground_color: 1, 1, 1, 1
                    padding: [dp(10), dp(10)]
                    canvas.before:
                        Color:
                            rgba: 1, 1, 1, 0.2
                        Line:
                            rounded_rectangle: [self.x, self.y, self.width, self.height, dp(5)]
                            width: dp(1)
                BoxLayout:
                    spacing: dp(15)
                    padding: [0, dp(15), 0, 0]
                    WalletAction:
                        icon: 'assets/green_up.png'
                        text: 'Deposit'
                        on_release: root.process_transaction('deposit')
                    WalletAction:
                        icon: 'assets/red_down.png'
                        text: 'Withdraw'
                        on_release: root.process_transaction('withdraw')
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(10)
                
                Label:
                    text: '[b]Recent Transactions[/b]'
                    markup: True
                    font_size: sp(16)
                    color: 1, 1, 1, 1
                    size_hint_y: None
                    height: dp(40)
                    text_size: self.size
                    halign: 'left'
                    valign: 'middle'
                BoxLayout:
                    id: history_list  
                    orientation: 'vertical'
                    size_hint_y: None
                    spacing: dp(10)
                    padding: [0, 0, 0, dp(15)]

# -------------------------------
# PAGE: Settings & Logout
# -------------------------------
<UserSettings>:
    orientation: 'vertical'
    padding: [dp(20), dp(5), dp(20), dp(20)]
    spacing: dp(10)
    ScrollView:
        do_scroll: False, True
        bar_width: 0               
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height
            spacing: dp(25)
            padding: [0, dp(15), 0, dp(20)]
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(10)
                Label:
                    text: 'ACCOUNT'
                    font_size: sp(12)
                    color: 0.6, 0.6, 0.6, 1
                    text_size: self.size
                    halign: 'left'
                    size_hint_y: None
                    height: dp(20)
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: self.minimum_height
                    canvas.before:
                        Color:
                            rgba: 0.11, 0.12, 0.16, 1
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(12)]
                    SettingsTile:
                        icon_source: 'assets/lock.png'
                        title: 'Privacy & Security'
                        subtitle: 'Password, 2FA, sessions'
                    Divider:
                    SettingsTile:
                        icon_source: 'assets/bank.png'
                        title: 'Payment Methods'
                        subtitle: 'Cards, wallets, escrow'
                    Divider:
                    SettingsTile:
                        icon_source: 'assets/university.png'
                        title: 'University'
                        subtitle: 'State University'
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(10)
                Label:
                    text: 'PREFERENCES'
                    font_size: sp(12)
                    color: 0.6, 0.6, 0.6, 1
                    text_size: self.size
                    halign: 'left'
                    size_hint_y: None
                    height: dp(20)
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: self.minimum_height
                    canvas.before:
                        Color:
                            rgba: 0.11, 0.12, 0.16, 1
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(12)]
                    SettingsTile:
                        icon_source: 'assets/notification.png'
                        title: 'Notifications'
                        subtitle: 'Push, email, SMS'
                    Divider:
                    SettingsTile:
                        icon_source: 'assets/display.png'
                        title: 'Appearance'
                        subtitle: 'Theme & display'
                    Divider:
                    SettingsTile:
                        icon_source: 'assets/language.png'
                        title: 'Language'
                        subtitle: 'English (US)'
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(10)
                Label:
                    text: 'SUPPORT'
                    font_size: sp(12)
                    color: 0.6, 0.6, 0.6, 1
                    text_size: self.size
                    halign: 'left'
                    size_hint_y: None
                    height: dp(20)
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: self.minimum_height
                    canvas.before:
                        Color:
                            rgba: 0.11, 0.12, 0.16, 1
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(12)]
                    SettingsTile:
                        icon_source: 'assets/help.png' 
                        title: 'Help Center'
                        subtitle: 'FAQs & guides'

<LogOut>:
    size: root.size
    pos: root.pos
    BoxLayout:
        orientation: 'vertical'
        size_hint: 0.85, None
        height: self.minimum_height
        pos_hint: {'center_x': 0.5, 'center_y': 0.6}
        spacing: dp(20)
        FloatLayout:
            size_hint_y: None
            height: dp(80)
            canvas.before:
                Color:
                    rgba: 0.15, 0.05, 0.05, 1
                Ellipse:
                    pos: [self.center_x - dp(40), self.y]
                    size: dp(80), dp(80)
            Image:
                source: 'assets/logout.png' 
                size_hint: 0.5, 0.5
                pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                color: (0.77, 0.1, 0.035, 1)
        Label:
            text: '[b]Sign Out?[/b]'
            markup: True
            font_size: sp(24)
            size_hint_y: None
            height: dp(30)
        Label:
            text: 'Are you sure you want to sign out of ScholarBridge?'
            color: 0.6, 0.6, 0.6, 1
            text_size: self.width, None
            halign: 'center'
            size_hint_y: None
            height: self.texture_size[1]
        Label:
            text: 'Active escrow transactions are safe'
            color: 0.16, 0.67, 0.38, 1
            font_size: sp(12)
            size_hint_y: None
            height: dp(20)
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: dp(120)
            spacing: dp(15)
            padding: [0, dp(10), 0, 0]
            Button:
                text: '[b]Sign Out[/b]'
                markup: True
                background_color: 0,0,0,0
                canvas.before:
                    Color:
                        rgba: 0.88, 0.25, 0.25, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(12)]
                on_release: 
                    root.perform_logout()
                    app.root.get_screen('main').toggle_footer(True)
                    app.root.get_screen('main').ids.dashboard.state = 'down'
                    app.root.get_screen('main').ids.info.state = 'normal'
            Button:
                text: '[b]Cancel[/b]'
                markup: True
                background_color: 0,0,0,0
                canvas.before:
                    Color:
                        rgba: 0.11, 0.12, 0.16, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(12)]
                    Color:
                        rgba: 0.3, 0.3, 0.3, 1
                    Line:
                        rounded_rectangle: [self.x, self.y, self.width, self.height, dp(12)]
                        width: dp(1)
                on_release:
                    root.parent.manager.current = 'menu'
                    root.parent.parent.parent.parent.parent.parent.parent.ids.label1.text = '[b]MENU[/b]'
                    root.parent.parent.parent.parent.parent.parent.parent.ids.label2.text = 'manage your account'
                    root.parent.parent.parent.parent.parent.parent.parent.ids.back_btn.opacity = 0
                    root.parent.parent.parent.parent.parent.parent.parent.ids.back_btn.disabled = True


# ==========================================
# DOMAIN: REUSABLE UI COMPONENTS
# ==========================================

# -------------------------------
# COMPONENT: Buttons & Inputs
# -------------------------------
<PrimaryButton@ButtonBehavior+FloatLayout>:
    text: ''
    size_hint_y: None
    height: dp(55)
    canvas.before:
        Color:
            rgba: (0.42, 0.35, 0.88, 1) if self.state == 'normal' else (0.3, 0.25, 0.7, 1)
        RoundedRectangle:
            size: self.size
            pos: self.pos
            radius: [dp(27)] 
    Label:
        text: root.text
        markup: True
        font_size: sp(16)
        pos_hint: {'center_x': 0.5, 'center_y': 0.5}

<SelectionBadge@ToggleButton>:
    background_normal: ''
    background_down: ''
    background_color: 0, 0, 0, 0 
    markup: True
    color: (1, 1, 1, 1) if self.state == 'down' else (0.6, 0.6, 0.6, 1)
    size_hint_x: None
    canvas.before:
        Color:
            rgba: (0.42, 0.35, 0.88, 0.4) if self.state == 'down' else (1, 1, 1, 0.05)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(12)]

<NavBackButton@ButtonBehavior+BoxLayout>:
    size_hint: None, None
    size: dp(40), dp(40)
    canvas.before:
        Color:
            rgba: 0.15, 0.16, 0.22, 1
        RoundedRectangle:
            size: self.size
            pos: self.pos
            radius: [dp(10)]
    Label:
        text: '<'
        font_size: sp(18)
        bold: True
        pos_hint: {'center_x': 0.5, 'center_y': 0.5}

<EditProfileButton@ButtonBehavior+FloatLayout>:
    size_hint_y: None
    height: dp(50)
    canvas.before:
        Color:
            rgba: 0.43, 0.33, 0.85, 1
        Line:
            rounded_rectangle: [self.x, self.y, self.width, self.height, dp(12)]
            width: dp(1.2)
    BoxLayout:
        spacing: dp(8)
        size_hint: None, 1
        width: self.minimum_width
        pos_hint: {'center_x': 0.5}
        Image:
            source: 'assets/edit.png'
            size_hint_x: None
            width: dp(18)
        Label:
            text: '[b]Edit Profile[/b]'
            markup: True
            color: 1, 1, 1, 1
            size_hint_x: None
            width: self.texture_size[0]

<IconButton@ButtonBehavior+AnchorLayout>:
    icon_source: ''
    icon_size_hint: 0.5, 0.5
    canvas.before:
        Color:
            rgba: (1, 1, 1, 0)
        Rectangle:
            pos: self.pos
            size: self.size
    Image:
        source: root.icon_source
        size_hint: root.icon_size_hint

<SendButton@ButtonBehavior+AnchorLayout>:
    icon_source: 'assets/send.png'
    Image:
        source: root.icon_source
        size_hint: 0.45, 0.45

<FormInput@BoxLayout>:
    orientation: 'vertical'
    size_hint_y: None
    height: dp(80)
    spacing: dp(8)
    title: ''
    hint: ''
    text_val: internal_input.text
    multilined: False
    Label:
        text: root.title
        font_size: sp(14)
        bold: True
        size_hint_y: None
        height: dp(20)
        text_size: self.size
        halign: 'left'
        valign: 'middle'
    BoxLayout:
        pos_hint: {'center_y': 0.5}
        padding: [dp(15), 0]
        canvas.before:
            Color:
                rgba: 0.11, 0.13, 0.18, 1
            RoundedRectangle:
                size: self.size
                pos: self.pos
                radius: [dp(8)]
            Color:
                rgba: 1, 1, 1, 0.1
            Line:
                rounded_rectangle: [self.x, self.y, self.width, self.height, dp(8)]
                width: dp(1)
        TextInput:
            id: internal_input
            hint_text: root.hint
            hint_text_color: 1, 1, 1, 0.4
            background_normal: ''
            background_active: ''
            foreground_color: 1, 1, 1, 1
            background_color: 0, 0, 0, 0
            cursor_color: 0.42, 0.35, 0.88, 1
            multiline: root.multilined
            padding: [dp(15), dp(15), dp(15), dp(15)] if root.multilined else [dp(15), (self.height - self.line_height) / 2, dp(15), (self.height - self.line_height) / 2]

# -------------------------------
# COMPONENT: Cards & Tiles
# -------------------------------
<EscrowBanner@BoxLayout>:
    size_hint_y: None
    height: dp(60)
    padding: dp(15)
    spacing: dp(15)
    canvas.before:
        Color:
            rgba: 0.08, 0.14, 0.16, 1 
        RoundedRectangle:
            size: self.size
            pos: self.pos
            radius: [dp(12)]
    Image:
        source: 'assets/green_shield.png'
        size_hint_x: None
        width: dp(24)
    BoxLayout:
        orientation: 'vertical'
        Label:
            text: '[b]Escrow Protected[/b]'
            markup: True
            color: 0.15, 0.76, 0.51, 1
            font_size: sp(14)
            text_size: self.size
            halign: 'left'
            valign: 'bottom'
        Label:
            text: 'Payment held securely until the buyer confirms receipt'
            color: 1, 1, 1, 0.6
            font_size: sp(11)
            text_size: self.size
            halign: 'left'
            valign: 'top'

<CardBase@BoxLayout>:
    canvas.before:
        Color:
            rgba: 0.11, 0.12, 0.16, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(12)]

<ListTile>:
    size_hint_y: None
    height: dp(70)
    padding: dp(15)
    spacing: dp(15)
    canvas.before:
        Color:
            rgba: 0.11, 0.12, 0.16, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(12)]
    FloatLayout:
        size_hint: None, None
        size: dp(40), dp(40)
        pos_hint: {'center_y': 0.5}
        canvas.before:
            Color:
                rgba: 0.15, 0.16, 0.22, 1
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(10)]
        Image:
            source: root.icon_source
            size_hint: 0.5, 0.5
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
    BoxLayout:
        orientation: 'vertical'
        spacing: dp(2)
        pos_hint: {'center_y': 0.5}
        Label:
            text: root.title
            font_size: sp(16)
            bold: True
            color: 1, 1, 1, 1
            text_size: self.size
            halign: 'left'
            valign: 'bottom'
        Label:
            text: root.subtitle
            font_size: sp(12)
            color: 0.6, 0.6, 0.6, 1
            text_size: self.size
            halign: 'left'
            valign: 'top'
    Label:
        text: '>' if root.show_arrow else ''
        size_hint_x: None
        width: dp(20)
        color: 0.5, 0.5, 0.5, 1
        font_size: sp(18)

<WalletAction@ButtonBehavior+BoxLayout>:
    orientation: 'horizontal'
    padding: [dp(20), dp(10)]
    spacing: dp(10)
    icon: ''
    text: ''
    canvas.before:
        Color:
            rgba: 1, 1, 1, 0.2
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(10)]
    Label:
        text: root.text
        bold: True
        font_size: sp(14)
        text_size: self.size
        halign: 'center'
        valign: 'middle'

<ChatBubble>:
    size_hint_y: None
    height: self.minimum_height
    padding: [dp(10), dp(5)]
    AnchorLayout:
        anchor_x: 'right' if root.is_sender else 'left'
        size_hint_y: None
        height: bubble_container.height
        BoxLayout:
            id: bubble_container
            orientation: 'vertical'
            size_hint: None, None
            width: min(dp(250), root.width * 0.75)
            height: self.minimum_height
            padding: dp(15)
            spacing: dp(5)
            canvas.before:
                Color:
                    rgba: (0.43, 0.33, 0.85, 1) if root.is_sender else (0.15, 0.16, 0.22, 1)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(15), dp(15), dp(0) if root.is_sender else dp(15), dp(15) if root.is_sender else dp(0)]
            Label:
                text: root.text
                size_hint_y: None
                height: self.texture_size[1]
                text_size: self.width, None
                color: 1, 1, 1, 1
            Label:
                text: root.time
                font_size: sp(10)
                size_hint_y: None
                height: dp(12)
                text_size: self.width, None
                halign: 'right' if root.is_sender else 'left'
                color: 0.8, 0.8, 0.8, 0.7

<MenuItem@ButtonBehavior+BoxLayout>:
    size_hint_y: None
    height: dp(55)
    spacing: dp(15)
    padding: [dp(10), dp(5), dp(10), dp(5)]
    opacity: 0.5 if self.state == 'down' else 1.0
    icon_source: ''
    text: ''
    text_color: 1, 1, 1, 1
    icon_bg_color: 0.12, 0.13, 0.20, 1
    badge_count: 0
    FloatLayout:
        size_hint_x: None
        width: dp(45)
        canvas.before:
            Color:
                rgba: root.icon_bg_color
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(12)]
        Image:
            source: root.icon_source
            size_hint: 0.5, 0.5
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
    Label:
        text: root.text
        color: root.text_color
        font_size: sp(16)
        bold: True
        text_size: self.size
        halign: 'left'
        valign: 'middle'
    Label:
        text: str(root.badge_count) if root.badge_count > 0 else ""
        size_hint_x: None
        width: dp(30) if root.badge_count > 0 else 0
        color: 1, 1, 1, 1
        font_size: sp(12)
        bold: True
        canvas.before:
            Color:
                rgba: (0.88, 0.25, 0.25, 1) if root.badge_count > 0 else (0,0,0,0)
            RoundedRectangle:
                size: [dp(22), dp(22)]
                pos: [self.center_x - dp(11), self.center_y - dp(11)]
                radius: [dp(11)]

<SettingsTile@BoxLayout>:
    size_hint_y: None
    height: dp(70)
    padding: dp(15)
    spacing: dp(15)
    icon_source: ''
    title: ''
    subtitle: ''
    FloatLayout:
        size_hint: None, None
        size: dp(40), dp(40)
        pos_hint: {'center_y': 0.5}
        canvas.before:
            Color:
                rgba: 0.15, 0.16, 0.22, 1
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(10)]
        Image:
            source: root.icon_source
            size_hint: 0.5, 0.5
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
    BoxLayout:
        orientation: 'vertical'
        spacing: dp(2)
        pos_hint: {'center_y': 0.5}
        Label:
            text: root.title
            font_size: sp(16)
            bold: True
            color: 1, 1, 1, 1
            text_size: self.size
            halign: 'left'
            valign: 'bottom'
        Label:
            text: root.subtitle
            font_size: sp(12)
            color: 0.6, 0.6, 0.6, 1
            text_size: self.size
            halign: 'left'
            valign: 'top'
    Label:
        text: '>'
        size_hint_x: None
        width: dp(20)
        color: 0.5, 0.5, 0.5, 1
        font_size: sp(18)

<InboxTile>:
    size_hint_y: None
    height: dp(85)
    padding: dp(15)
    spacing: dp(15)
    on_release: self.open_chat()
    canvas.before:
        Color:
            rgba: (0.15, 0.16, 0.22, 1) if self.state == 'normal' else (0.20, 0.21, 0.28, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(15)]
    FloatLayout:
        size_hint_x: None
        width: dp(50)
        canvas.before:
            Color:
                rgba: 0.43, 0.33, 0.85, 1
            Ellipse:
                pos: [self.center_x - dp(25), self.center_y - dp(25)]
                size: dp(50), dp(50)
        Label:
            text: f'[b]{root.partner_name[0:2].upper() if root.partner_name else ""}[/b]'
            markup: True
            font_size: sp(16)
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
    BoxLayout:
        orientation: 'vertical'
        spacing: dp(2)
        Label:
            text: f'[b]{root.partner_name}[/b]'
            markup: True
            font_size: sp(16)
            text_size: self.size
            halign: 'left'
            valign: 'bottom'
        Label:
            text: root.last_message
            color: 0.6, 0.6, 0.6, 1
            font_size: sp(13)
            text_size: self.size
            halign: 'left'
            valign: 'top'
            shorten: True
            shorten_from: 'right'
    Label:
        size_hint_x: None
        width: dp(65)
        text: root.time
        color: 0.5, 0.5, 0.5, 1
        font_size: sp(11)
        text_size: self.size
        halign: 'right'
        valign: 'top'

<OwnedItemTile@BoxLayout>:
    title: ''
    subtitle: ''
    seller_name: '' 
    icon_bg: 0.15, 0.16, 0.22, 1
    size_hint_y: None
    height: dp(90) 
    padding: dp(15)
    spacing: dp(15)
    canvas.before:
        Color:
            rgba: 0.11, 0.12, 0.16, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(15)]
    FloatLayout:
        size_hint: None, None
        size: dp(45), dp(45)
        pos_hint: {'center_y': 0.5} 
        canvas.before:
            Color:
                rgba: root.icon_bg
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(10)]
        Image:
            source: 'assets/check_solid.png'
            size_hint: 0.5, 0.5
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
    BoxLayout:
        orientation: 'vertical'
        pos_hint: {'center_y': 0.5}
        Label:
            text: f'[b]{root.title}[/b]'
            markup: True
            font_size: sp(16)
            size_hint_y: None
            height: dp(22)
            text_size: self.size
            halign: 'left'
            valign: 'bottom'
            shorten: True
            shorten_from: 'right'
        Label:
            text: root.subtitle
            color: 0.6, 0.6, 0.6, 1
            font_size: sp(13)
            size_hint_y: None
            text_size: self.width, None      
            height: self.texture_size[1]      
            halign: 'left'
            valign: 'top'
    Button:
        text: '[b]Rate[/b]'
        markup: True
        size_hint: None, None
        size: dp(70), dp(35)
        pos_hint: {'center_y': 0.5}
        background_color: 0,0,0,0
        on_release: app.root.get_screen('main').ids.screenmanager.get_screen('info').children[0].ids.screenmanager.get_screen('inbox').children[0].open_review(root.seller_name)
        canvas.before:
            Color:
                rgba: 1, 0.8, 0.2, 0.8
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(8)]

<SubscriptionItemTile@BoxLayout>:
    title: ''
    schedule: ''
    seller_name: ''
    service_id: 0
    size_hint_y: None
    height: dp(110) 
    padding: dp(15)
    spacing: dp(10)
    canvas.before:
        Color:
            rgba: 0.15, 0.12, 0.20, 1 
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(15)]
    BoxLayout:
        orientation: 'vertical'
        pos_hint: {'center_y': 0.5}
        Label:
            text: f'[b]{root.title}[/b]'
            markup: True
            font_size: sp(16)
            text_size: self.size
            halign: 'left'
            valign: 'bottom'
        Label:
            text: f'Starts: {root.schedule}'
            color: 0.43, 0.33, 0.85, 1 
            font_size: sp(13)
            text_size: self.size
            halign: 'left'
            valign: 'top'
    BoxLayout:
        orientation: 'vertical' 
        size_hint_x: None
        width: dp(100)           
        spacing: dp(8)           
        pos_hint: {'center_y': 0.5}
        Button:
            text: 'Rate'
            size_hint: 1, None   
            height: dp(32)
            background_color: 0,0,0,0
            on_release: app.root.get_screen('main').ids.screenmanager.get_screen('info').children[0].ids.screenmanager.get_screen('inbox').children[0].open_review(root.seller_name)
            canvas.before:
                Color:
                    rgba: 1, 0.8, 0.2, 0.8 
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(8)]
        Button:
            text: 'Unsubscribe'
            size_hint: 1, None   
            height: dp(32)
            background_color: 0,0,0,0
            on_release: app.root.get_screen('main').ids.screenmanager.get_screen('info').children[0].ids.screenmanager.get_screen('inbox').children[0].unsubscribe(root.service_id)
            canvas.before:
                Color:
                    rgba: 0.85, 0.26, 0.33, 1 
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(8)]

<Divider@Widget>:
    size_hint_y: None
    height: dp(1)
    canvas.before:
        Color:
            rgba: 0.15, 0.16, 0.22, 1
        Rectangle:
            pos: self.pos
            size: self.size
